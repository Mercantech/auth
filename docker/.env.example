# Kopiér til .env i samme mappe som docker-compose.yml og udfyld (commit ikke .env)
# cp .env.example .env

ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=mercantec_auth;Username=auth;Password=auth

Auth__EnableEmailPasswordLogin=true

Jwt__Issuer=https://auth.mercantec.tech
Jwt__Audience=mercantec-apps

Cors__SpaOrigins__0=http://localhost:5173
Cors__SpaOrigins__1=http://127.0.0.1:5173

# E-mail — lokal docker med Mailpit (http://localhost:8025)
Email__Enabled=true
Email__SmtpHost=mailpit
Email__SmtpPort=1025
Email__UseStartTls=false
Email__FromAddress=noreply@auth.mercantec.tech
Email__FromName=Mercantec Auth (docker)
Email__PublicBaseUrl=http://localhost:8080

# E-mail — Brevo SMTP (produktion / test mod rigtig indbakke)
# Brug SMTP-nøglen fra Brevo → SMTP & API → SMTP (IKKE API v3-nøglen)
# Email__SmtpHost=smtp-relay.brevo.com
# Email__SmtpPort=587
# Email__UseStartTls=true
# Email__SmtpUser=din-brevo-login-email
# Email__SmtpPassword=din-brevo-smtp-key
# Email__FromAddress=noreply@auth.mercantec.tech
# Email__FromName=Mercantec Auth
# Email__PublicBaseUrl=https://auth.mercantec.tech

# Dokploy (valgfri) — brugere ved signup-opt-in + to-vejs projekt-ACL
# Dokploy__Enabled=true
# Dokploy__BaseUrl=https://deploy.mags.dk/api
# Dokploy__ApiKey=
# Dokploy__AclSyncIntervalMinutes=15
# Dokploy__MemberRole=member

# OAuth__Microsoft__ClientId=
