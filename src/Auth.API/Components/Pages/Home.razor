@page "/"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Auth.API.Security

<PageTitle>Mercantec Auth</PageTitle>

<div class="home">
    <section class="home-hero">
        <div class="home-hero__inner">
            <p class="home-eyebrow">Identity provider · skole &amp; apps</p>
            <h1>Ét sted at logge ind</h1>
            <p class="home-lead">
                Central udsteder til jeres SPAs og API’er: <strong>OAuth&nbsp;2.0</strong> med authorization code og
                <strong>PKCE</strong>, korte <strong>JWT</strong> (RS256) og refresh tokens.
            </p>
            <p class="home-attribution" role="note">
                Platform ved <strong>MAGS</strong> (underviser) — ikke Mercantecs officielle auth-tjeneste.
                Spørgsmål: <a href="mailto:mags@mercantec.dk">mags@mercantec.dk</a>
            </p>
        </div>
    </section>

    <div class="home-grid">
        <aside class="home-aside">
            <AuthorizeView>
                <Authorized Context="authState">
                    @{
                        var u = authState.User;
                        var method = u.FindFirstValue(MercantecAuthClaims.LoginMethod);
                        var roles = u.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();
                    }
                    <div class="home-card home-card--session home-card--ok">
                        <p class="home-card__title-sm">Session</p>
                        <div class="home-pill home-pill--in">Logget ind</div>
                        <p class="home-fact"><strong>Navn</strong> @(u.Identity?.Name ?? "—")</p>
                        <p class="home-fact"><strong>Metode</strong> @LoginMethodDa(method)</p>
                        <p class="home-fact"><strong>Roller</strong> @(roles.Count > 0 ? string.Join(", ", roles) : "Ingen (kun basis-bruger)")</p>
                        <p class="home-fact"><strong>Bruger-ID</strong> <code>@u.FindFirstValue(ClaimTypes.NameIdentifier)</code></p>
                        <a class="merc-btn merc-btn--ghost" href="/signout">Log ud</a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="home-card home-card--session">
                        <p class="home-card__title-sm">Session</p>
                        <div class="home-pill">Ikke logget ind</div>
                        <p class="home-note" style="margin-top:0">
                            Apps der starter OAuth sendes hertil eller til <code>/Account/Login</code> når der mangler session.
                        </p>
                        <a class="merc-btn merc-btn--primary" href="/Account/Login">Log ind</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </aside>

        <div class="home-main">
            <h2 class="home-section-title">Endepunkter</h2>
            <ul class="home-endpoints" role="list">
                <li class="home-endpoint">
                    <span class="home-endpoint__method home-endpoint__method--get">GET</span>
                    <div>
                        <p class="home-endpoint__path"><code>/.well-known/jwks.json</code></p>
                        <p class="home-endpoint__desc">Offentlige nøgler til RS256-verifikation af access tokens.</p>
                    </div>
                </li>
                <li class="home-endpoint">
                    <span class="home-endpoint__method home-endpoint__method--get">GET</span>
                    <div>
                        <p class="home-endpoint__path"><code>/.well-known/mercantec-auth.json</code></p>
                        <p class="home-endpoint__desc">Integrations-manifest til nye klienter og værktøjer.</p>
                    </div>
                </li>
                <li class="home-endpoint">
                    <span class="home-endpoint__method home-endpoint__method--get">GET</span>
                    <div>
                        <p class="home-endpoint__path"><code>/oauth/authorize</code></p>
                        <p class="home-endpoint__desc">Start login-flow (redirect til login uden gyldig cookie-session).</p>
                    </div>
                </li>
                <li class="home-endpoint">
                    <span class="home-endpoint__method home-endpoint__method--post">POST</span>
                    <div>
                        <p class="home-endpoint__path"><code>/oauth/token</code></p>
                        <p class="home-endpoint__desc">Byt authorization <code>code</code> til access/refresh token (PKCE ved offentlige klienter).</p>
                    </div>
                </li>
                <li class="home-endpoint">
                    <span class="home-endpoint__method home-endpoint__method--get">GET</span>
                    <div>
                        <p class="home-endpoint__path"><code>/health</code></p>
                        <p class="home-endpoint__desc">Simpelt liveness-check for drift og compose.</p>
                    </div>
                </li>
            </ul>
            <p class="home-note">
                I udvikling oprettes en demo-klient <code>demo</code> med callback på localhost (bl.a. port <code>5173</code>).
                Brug rigtig PKCE (S256) — se <code>docs/CLIENT-INTEGRATION.md</code>.
            </p>
        </div>
    </div>
</div>

@code {
    private static string LoginMethodDa(string? m) => m switch
    {
        MercantecAuthClaims.LoginMethodValues.Password => "E-mail og adgangskode",
        MercantecAuthClaims.LoginMethodValues.Google => "Google",
        MercantecAuthClaims.LoginMethodValues.GitHub => "GitHub",
        MercantecAuthClaims.LoginMethodValues.Discord => "Discord",
        MercantecAuthClaims.LoginMethodValues.Microsoft => "Microsoft",
        MercantecAuthClaims.LoginMethodValues.MicrosoftWork => "Microsoft 365 (arbejde/skole)",
        MercantecAuthClaims.LoginMethodValues.MicrosoftSchool => "Microsoft (skole)",
        MercantecAuthClaims.LoginMethodValues.Unknown => "Ukendt",
        _ => string.IsNullOrWhiteSpace(m) ? "—" : m,
    };
}
