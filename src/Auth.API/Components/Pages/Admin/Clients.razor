@page "/Admin/Clients"
@attribute [Authorize(Roles = "Admin")]
@using Auth.API.Services
@inject AuthDbContext Db
@inject IWebHostEnvironment Env
@inject IJSRuntime Js
@inject IConfiguration Config
@inject IOptions<AuthOptions> AuthOptions
@using Auth.API.Models.Entities
@using Auth.API.Options
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using System.Text.RegularExpressions

<PageTitle>Klienter (admin)</PageTitle>

<div class="merc-page merc-clients">
    <header class="merc-clients__header">
        <div>
            <h1>Klienter</h1>
            <p class="merc-clients__lead">
                Registrér OAuth-klienter, redirect-URI’er og PKCE/secret-indstillinger til jeres apps.
            </p>
        </div>
        <a class="merc-btn merc-btn--ghost" href="/.well-known/mercantec-auth.json" target="_blank" rel="noopener">Integrations-manifest</a>
    </header>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="merc-alert @(_statusIsError ? "merc-alert--error" : "merc-alert--ok")" role="status">
            @_status
        </div>
    }

    @if (_clients is null)
    {
        <p class="merc-clients__loading">Henter klienter…</p>
    }
    else
    {
        <div class="merc-clients__layout">
            <aside class="merc-clients__sidebar" aria-label="Klientliste">
                <button type="button"
                        class="merc-btn merc-btn--primary merc-clients__new-btn"
                        @onclick="OpenCreatePanel">
                    + Ny klient
                </button>

                @if (_clients.Count == 0)
                {
                    <p class="merc-clients__sidebar-empty">Ingen klienter endnu. Opret den første ovenfor.</p>
                }
                else
                {
                    <ul class="merc-clients__list" role="list">
                        @foreach (var c in _clients.OrderBy(x => x.Name))
                        {
                            var isSelected = _selected?.Id == c.Id && !_showCreate;
                            <li>
                                <button type="button"
                                        class="merc-clients__item @(isSelected ? "merc-clients__item--active" : null)"
                                        aria-current="@(isSelected ? "true" : null)"
                                        @onclick="() => SelectClientAsync(c.Id)">
                                    <span class="merc-clients__item-name">@c.Name</span>
                                    <span class="merc-clients__item-id"><code>@c.ClientId</code></span>
                                    <span class="merc-clients__item-badges">
                                        @if (!c.IsActive)
                                        {
                                            <span class="merc-badge merc-badge--muted">Inaktiv</span>
                                        }
                                        <span class="merc-badge @(c.IsPublic ? "merc-badge--public" : "merc-badge--confidential")">
                                            @(c.IsPublic ? "Public" : "Fortrolig")
                                        </span>
                                        <span class="merc-badge merc-badge--count">@c.RedirectUris.Count URI</span>
                                    </span>
                                </button>
                            </li>
                        }
                    </ul>
                }
            </aside>

            <div class="merc-clients__main">
                <div class="merc-clients__canvas">
                @if (_showCreate)
                {
                    <section class="merc-panel" aria-labelledby="create-heading">
                        <div class="merc-panel__head">
                            <div>
                                <h2 id="create-heading">Opret ny klient</h2>
                                <p class="merc-panel__sub">Trin 1: identitet · Trin 2: type · derefter tilføj redirect-URI’er</p>
                            </div>
                            <button type="button" class="merc-btn merc-btn--ghost" @onclick="CloseCreatePanel">Annuller</button>
                        </div>

                        <div class="merc-form-grid merc-form-grid--2">
                            <div class="merc-field">
                                <label class="merc-label" for="newName">App-navn</label>
                                <input id="newName" class="merc-input" placeholder="Min elevportal" @bind="_newClientName" @bind:event="oninput" @bind:after="OnNewNameChanged" />
                                <span class="merc-hint">Vises til admins; ikke sendt til OAuth.</span>
                            </div>
                            <div class="merc-field">
                                <label class="merc-label" for="newClientId">Client ID</label>
                                <input id="newClientId" class="merc-input" placeholder="min-elevportal" @bind="_newClientId" @bind:after="OnNewClientIdChanged" />
                                <span class="merc-hint">Parameter <code>client_id</code> — små bogstaver, tal, <code>-</code>, <code>_</code>, <code>.</code></span>
                            </div>
                        </div>

                        <fieldset class="merc-fieldset">
                            <legend class="merc-label">Klienttype</legend>
                            <div class="merc-choice-grid">
                                <button type="button"
                                        class="merc-choice @( _newClientKind == ClientKind.Spa ? "merc-choice--selected" : null)"
                                        @onclick="() => SetNewClientKind(ClientKind.Spa)">
                                    <span class="merc-choice__title">Webapp / SPA</span>
                                    <span class="merc-choice__desc">Public klient uden secret. PKCE (S256) anbefales.</span>
                                </button>
                                <button type="button"
                                        class="merc-choice @( _newClientKind == ClientKind.Confidential ? "merc-choice--selected" : null)"
                                        @onclick="() => SetNewClientKind(ClientKind.Confidential)">
                                    <span class="merc-choice__title">Server / fortrolig</span>
                                    <span class="merc-choice__desc">Har client secret ved token-kald. Til backends.</span>
                                </button>
                            </div>
                        </fieldset>

                        <label class="merc-check">
                            <input type="checkbox" @bind="_newIsActive" />
                            <span>Klient er aktiv (kan bruges til login med det samme)</span>
                        </label>

                        <div class="merc-panel__actions">
                            <button type="button" class="merc-btn merc-btn--primary" @onclick="CreateClientAsync" disabled="@_saving">
                                @(_saving ? "Opretter…" : "Opret klient")
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_newClientSecretPlain))
                        {
                            <div class="merc-secret-box" role="alert">
                                <p class="merc-secret-box__title">Gem client secret nu — vises ikke igen</p>
                                <div class="merc-secret-box__row">
                                    <input class="merc-input merc-input--mono" readonly value="@_newClientSecretPlain" aria-label="Client secret" />
                                    <button type="button" class="merc-btn merc-btn--ghost" @onclick="() => CopyToClipboardAsync(_newClientSecretPlain)">Kopiér</button>
                                </div>
                            </div>
                        }
                    </section>
                }
                else if (_selected is null)
                {
                    <div class="merc-clients__empty">
                        <h2>Vælg en klient</h2>
                        <p>Klik en klient i listen til venstre, eller opret en ny OAuth-klient.</p>
                        @if (_clients.Count > 0)
                        {
                            <button type="button" class="merc-btn merc-btn--primary" @onclick="() => SelectClientAsync(_clients[0].Id)">
                                Åbn @_clients.OrderBy(c => c.Name).First().Name
                            </button>
                        }
                    </div>
                }
                else
                {
                    <section class="merc-panel merc-clients__detail">
                        <div class="merc-panel__head">
                            <div>
                                <h2>@_selected.Name</h2>
                                <p class="merc-panel__sub"><code>client_id=@_selected.ClientId</code></p>
                            </div>
                            <div class="merc-clients__detail-badges">
                                <span class="merc-badge @(_selected.IsActive ? "merc-badge--ok" : "merc-badge--muted")">
                                    @(_selected.IsActive ? "Aktiv" : "Inaktiv")
                                </span>
                                <span class="merc-badge @(_selected.IsPublic ? "merc-badge--public" : "merc-badge--confidential")">
                                    @(_selected.IsPublic ? "Public" : "Fortrolig")
                                </span>
                                @if (_selected.RequirePkce)
                                {
                                    <span class="merc-badge merc-badge--pkce">PKCE</span>
                                }
                            </div>
                        </div>

                        <div class="merc-tabs" role="tablist" aria-label="Klientsektioner">
                            <button type="button" role="tab" class="merc-tabs__btn @(_activeTab == ClientTab.Settings ? "merc-tabs__btn--active" : null)" aria-selected="@(_activeTab == ClientTab.Settings)" @onclick="() => _activeTab = ClientTab.Settings">Indstillinger</button>
                            <button type="button" role="tab" class="merc-tabs__btn @(_activeTab == ClientTab.Redirects ? "merc-tabs__btn--active" : null)" aria-selected="@(_activeTab == ClientTab.Redirects)" @onclick="() => _activeTab = ClientTab.Redirects">
                                Redirect URI’er
                                <span class="merc-tabs__count">@_selected.RedirectUris.Count</span>
                            </button>
                        </div>

                        @if (_activeTab == ClientTab.Settings)
                        {
                            <div class="merc-form-grid merc-form-grid--2">
                                <div class="merc-field">
                                    <label class="merc-label" for="editName">App-navn</label>
                                    <input id="editName" class="merc-input" @bind="_editName" />
                                </div>
                                <div class="merc-field">
                                    <label class="merc-label" for="editClientId">Client ID</label>
                                    <input id="editClientId" class="merc-input" @bind="_editClientId" />
                                </div>
                                <label class="merc-check">
                                    <input type="checkbox" @bind="_editIsActive" />
                                    <span>Aktiv</span>
                                </label>
                                <label class="merc-check">
                                    <input type="checkbox" @bind="_editIsPublic" />
                                    <span>Public klient (ingen secret)</span>
                                </label>
                                <label class="merc-check">
                                    <input type="checkbox" @bind="_editRequirePkce" />
                                    <span>Kræv PKCE (S256)</span>
                                </label>
                            </div>

                            <div class="merc-field">
                                <label class="merc-label" for="editScopes">Tilladte scopes</label>
                                <input id="editScopes" class="merc-input" placeholder="openid profile email offline_access" @bind="_editAllowedScopes" />
                                <span class="merc-hint">Space-separeret. Dokumenterer hvilke scopes klienten må anmode om.</span>
                            </div>

                            <div class="merc-field">
                                <label class="merc-label" for="editLoginTheme">Login-tema (OAuth)</label>
                                <select id="editLoginTheme" class="merc-input" @bind="_editLoginThemeId">
                                    @foreach (var theme in LoginThemeCatalog.All)
                                    {
                                        <option value="@(theme.Id == LoginThemeCatalog.DefaultId ? "" : theme.Id)">@theme.DisplayName</option>
                                    }
                                </select>
                                <span class="merc-hint">Vises på Login, Register og MFA når brugeren starter OAuth med denne <code>client_id</code>. Tom = Mercantec standard.</span>
                            </div>

                            <fieldset class="merc-fieldset">
                                <legend class="merc-label">Login-metoder (OAuth)</legend>
                                <p class="merc-hint merc-hint--block">
                                    Styr hvilke login-metoder brugeren ser når de logger ind via denne klient.
                                    Kun metoder der også er aktiveret på serveren vises — tom liste = alle server-metoder.
                                </p>
                                <label class="merc-check">
                                    <input type="checkbox" checked="@_editUseAllLoginMethods" @onchange="OnUseAllLoginMethodsChanged" />
                                    <span>Alle aktiverede metoder på serveren (anbefalet)</span>
                                </label>
                                @if (!_editUseAllLoginMethods)
                                {
                                    @foreach (var group in ClientLoginMethodCatalog.All.GroupBy(m => m.Category))
                                    {
                                        <p class="merc-panel__h3">@group.Key</p>
                                        @foreach (var method in group)
                                        {
                                            var serverOn = _globalLoginMethods.IsAllowed(method.Id);
                                            <label class="merc-check @(serverOn ? null : "merc-check--muted")">
                                                <input type="checkbox"
                                                       checked="@_editLoginMethods.Contains(method.Id)"
                                                       disabled="@(!serverOn)"
                                                       @onchange="e => ToggleLoginMethod(method.Id, e)" />
                                                <span>@method.DisplayName@(!serverOn ? " (ikke konfigureret på serveren)" : "")</span>
                                            </label>
                                        }
                                    }
                                }
                            </fieldset>

                            <fieldset class="merc-fieldset">
                                <legend class="merc-label">Krævet tilknytning (OAuth)</legend>
                                <p class="merc-hint merc-hint--block">
                                    Brugeren skal have tilknyttet valgte udbydere på sin Mercantec-konto før appen udsteder OAuth-kode.
                                    De kan stadig logge ind med andre metoder — men bliver bedt om at tilknytte manglende udbydere undervejs.
                                </p>
                                @foreach (var group in ClientLoginMethodCatalog.ExternalProviders.GroupBy(m => m.Category))
                                {
                                    <p class="merc-panel__h3">@group.Key</p>
                                    @foreach (var method in group)
                                    {
                                        var serverOn = _globalLoginMethods.IsAllowed(method.Id);
                                        <label class="merc-check @(serverOn ? null : "merc-check--muted")">
                                            <input type="checkbox"
                                                   checked="@_editRequiredLinkedProviders.Contains(method.Id)"
                                                   disabled="@(!serverOn)"
                                                   @onchange="e => ToggleRequiredLinkedProvider(method.Id, e)" />
                                            <span>@method.DisplayName@(!serverOn ? " (ikke konfigureret på serveren)" : "")</span>
                                        </label>
                                    }
                                }
                            </fieldset>

                            <div class="merc-panel__actions">
                                <button type="button" class="merc-btn merc-btn--primary" @onclick="SaveClientSettingsAsync" disabled="@_saving">
                                    @(_saving ? "Gemmer…" : "Gem indstillinger")
                                </button>
                                <button type="button" class="merc-btn merc-btn--danger" @onclick="DeleteClientAsync" disabled="@_saving">
                                    @(_saving ? "Sletter…" : "Slet klient")
                                </button>
                            </div>

                            @if (!_editIsPublic)
                            {
                                <div class="merc-panel__divider"></div>
                                <h3 class="merc-panel__h3">Client secret</h3>
                                <p class="merc-hint">Secret hashes i databasen. Rotér hvis det er lækket.</p>
                                <button type="button" class="merc-btn merc-btn--ghost" @onclick="RotateClientSecretAsync" disabled="@_saving">Rotér secret</button>

                                @if (!string.IsNullOrWhiteSpace(_rotatedSecretPlain))
                                {
                                    <div class="merc-secret-box" role="alert">
                                        <p class="merc-secret-box__title">Nyt secret — gem det nu</p>
                                        <div class="merc-secret-box__row">
                                            <input class="merc-input merc-input--mono" readonly value="@_rotatedSecretPlain" />
                                            <button type="button" class="merc-btn merc-btn--ghost" @onclick="() => CopyToClipboardAsync(_rotatedSecretPlain)">Kopiér</button>
                                        </div>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <p class="merc-hint merc-hint--block">
                                OAuth kræver <strong>præcist match</strong> på <code>redirect_uri</code> (skema, host og path).
                                Produktion: <strong>https</strong>. Lokal udvikling: <code>http://localhost</code> eller <code>127.0.0.1</code>.
                            </p>

                            @if (_selected.RedirectUris.Count == 0)
                            {
                                <p class="merc-clients__uri-empty">Ingen redirect-URI’er — login fejler indtil mindst én er tilføjet.</p>
                            }
                            else
                            {
                                <ul class="merc-uri-list" role="list">
                                    @foreach (var r in _selected.RedirectUris.OrderBy(x => x.Uri, StringComparer.Ordinal))
                                    {
                                        <li class="merc-uri-list__row">
                                            <code class="merc-uri-list__uri">@r.Uri</code>
                                            <button type="button" class="merc-btn merc-btn--danger merc-btn--sm" @onclick="() => RemoveRedirectUriAsync(r.Id)" disabled="@_saving">Fjern</button>
                                        </li>
                                    }
                                </ul>
                            }

                            <div class="merc-panel__divider"></div>
                            <h3 class="merc-panel__h3">Tilføj redirect URI</h3>

                            <div class="merc-field">
                                <label class="merc-label" for="newUri">URI</label>
                                <div class="merc-input-row">
                                    <input id="newUri" class="merc-input" placeholder="https://min-app.example/callback" @bind="_newRedirectUri" @onkeydown="OnRedirectUriKeydown" />
                                    <button type="button" class="merc-btn merc-btn--primary" @onclick="AddRedirectUriAsync" disabled="@_saving">Tilføj</button>
                                </div>
                            </div>

                            @if (Env.IsDevelopment() || Env.IsEnvironment("Testing"))
                            {
                                <div class="merc-quick-add">
                                    <span class="merc-quick-add__label">Hurtig tilføj (dev):</span>
                                    @foreach (var preset in DevRedirectPresets)
                                    {
                                        <button type="button" class="merc-chip" @onclick="() => ApplyRedirectPreset(preset)">@preset</button>
                                    }
                                </div>
                            }
                        }
                    </section>
                }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private enum ClientTab { Settings, Redirects }
    private enum ClientKind { Spa, Confidential }

    private static readonly string[] DevRedirectPresets =
    [
        "http://localhost:5173/callback.html",
        "http://localhost:5155/oauth/callback",
        "http://localhost:8080/oauth/callback",
    ];

    private List<ClientApp>? _clients;
    private ClientApp? _selected;
    private string? _selectedClientId;
    private string _newRedirectUri = "";
    private string? _status;
    private bool _statusIsError;
    private bool _showCreate;
    private bool _saving;
    private ClientTab _activeTab = ClientTab.Settings;
    private bool _clientIdWasAuto = true;

    private string _newClientName = "";
    private string _newClientId = "";
    private ClientKind _newClientKind = ClientKind.Spa;
    private bool _newIsActive = true;
    private string? _newClientSecretPlain;

    private bool _editIsActive;
    private bool _editIsPublic;
    private bool _editRequirePkce;
    private string _editName = "";
    private string _editClientId = "";
    private string _editAllowedScopes = "";
    private string _editLoginThemeId = "";
    private bool _editUseAllLoginMethods = true;
    private HashSet<string> _editLoginMethods = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _editRequiredLinkedProviders = new(StringComparer.OrdinalIgnoreCase);
    private ClientLoginMethodsPolicy _globalLoginMethods = null!;
    private string? _rotatedSecretPlain;

    private bool _newIsPublic => _newClientKind == ClientKind.Spa;
    private bool _newRequirePkce => _newClientKind == ClientKind.Spa;

    protected override async Task OnInitializedAsync()
    {
        _globalLoginMethods = ClientLoginMethodsPolicy.FromGlobalConfiguration(Config, AuthOptions.Value);
        await ReloadAsync();
        if (_clients?.Count > 0 && _selected is null && !_showCreate)
            await SelectClientAsync(_clients.OrderBy(c => c.Name).First().Id);
    }

    private void OpenCreatePanel()
    {
        _showCreate = true;
        _selectedClientId = null;
        _selected = null;
        _newClientSecretPlain = null;
        _status = null;
        _statusIsError = false;
    }

    private void CloseCreatePanel()
    {
        _showCreate = false;
        _newClientSecretPlain = null;
        if (_clients?.Count > 0 && _selected is null)
            _ = SelectClientAsync(_clients.OrderBy(c => c.Name).First().Id);
    }

    private void SetNewClientKind(ClientKind kind) => _newClientKind = kind;

    private void OnNewNameChanged()
    {
        if (_clientIdWasAuto)
            _newClientId = SlugifyClientId(_newClientName);
    }

    private void OnNewClientIdChanged() => _clientIdWasAuto = false;

    private static string SlugifyClientId(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "";
        var s = name.Trim().ToLowerInvariant();
        s = Regex.Replace(s, @"\s+", "-");
        s = Regex.Replace(s, @"[^a-z0-9\-_.]", "");
        s = Regex.Replace(s, @"[-_.]{2,}", "-").Trim('-', '_', '.');
        return s.Length > 64 ? s[..64] : s;
    }

    private async Task SelectClientAsync(Guid id)
    {
        _showCreate = false;
        _selectedClientId = id.ToString();
        _status = null;
        _statusIsError = false;
        _newRedirectUri = "";
        _rotatedSecretPlain = null;
        _newClientSecretPlain = null;
        _activeTab = ClientTab.Settings;
        await ReloadAsync();
    }

    private void ApplyRedirectPreset(string uri)
    {
        _newRedirectUri = uri;
        _activeTab = ClientTab.Redirects;
    }

    private async Task OnRedirectUriKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await AddRedirectUriAsync();
    }

    private void SetStatus(string message, bool isError)
    {
        _status = message;
        _statusIsError = isError;
    }

    private async Task CopyToClipboardAsync(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return;
        try
        {
            await Js.InvokeVoidAsync("mercAuth.copyText", text);
            SetStatus("Kopieret til udklipsholder.", false);
        }
        catch
        {
            SetStatus("Kunne ikke kopiere — markér og kopiér manuelt.", true);
        }
    }

    private async Task ReloadAsync()
    {
        _clients = await Db.ClientApps
            .AsNoTracking()
            .Include(c => c.RedirectUris)
            .OrderBy(c => c.Name)
            .ToListAsync();

        _selected = null;
        if (!string.IsNullOrWhiteSpace(_selectedClientId) && Guid.TryParse(_selectedClientId, out var id))
            _selected = _clients.FirstOrDefault(c => c.Id == id);

        if (_selected is not null)
        {
            _editName = _selected.Name;
            _editClientId = _selected.ClientId;
            _editIsActive = _selected.IsActive;
            _editIsPublic = _selected.IsPublic;
            _editRequirePkce = _selected.RequirePkce;
            _editAllowedScopes = _selected.AllowedScopes ?? "";
            _editLoginThemeId = _selected.LoginThemeId ?? "";
            LoadLoginMethodsFromSelected(_selected.AllowedLoginMethods);
            _editRequiredLinkedProviders = ClientLoginMethodCatalog.ParseRequiredLinked(_selected.RequiredLinkedProviders);
            _rotatedSecretPlain = null;
        }
    }

    private void LoadLoginMethodsFromSelected(string? allowedLoginMethods)
    {
        _editUseAllLoginMethods = string.IsNullOrWhiteSpace(allowedLoginMethods);
        _editLoginMethods = _editUseAllLoginMethods
            ? DefaultEnabledLoginMethodIds()
            : ClientLoginMethodCatalog.ParseStored(allowedLoginMethods);
    }

    private HashSet<string> DefaultEnabledLoginMethodIds()
    {
        var set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var method in ClientLoginMethodCatalog.All)
        {
            if (_globalLoginMethods.IsAllowed(method.Id))
                set.Add(method.Id);
        }

        return set;
    }

    private void OnUseAllLoginMethodsChanged(ChangeEventArgs e)
    {
        _editUseAllLoginMethods = e.Value is true;
        if (_editUseAllLoginMethods)
            _editLoginMethods = DefaultEnabledLoginMethodIds();
    }

    private void ToggleLoginMethod(string methodId, ChangeEventArgs e)
    {
        if (e.Value is true)
            _editLoginMethods.Add(methodId);
        else
            _editLoginMethods.Remove(methodId);
    }

    private void ToggleRequiredLinkedProvider(string methodId, ChangeEventArgs e)
    {
        if (e.Value is true)
            _editRequiredLinkedProviders.Add(methodId);
        else
            _editRequiredLinkedProviders.Remove(methodId);
    }

    private static string GenerateSecret(int bytes = 32)
    {
        var b = System.Security.Cryptography.RandomNumberGenerator.GetBytes(bytes);
        return Convert.ToBase64String(b).TrimEnd('=').Replace('+', '-').Replace('/', '_');
    }

    private static bool IsValidClientId(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return false;
        value = value.Trim();
        if (value.Length < 2 || value.Length > 64)
            return false;
        foreach (var ch in value)
        {
            if (!(char.IsLetterOrDigit(ch) || ch is '-' or '_' or '.'))
                return false;
        }
        return true;
    }

    private async Task CreateClientAsync()
    {
        SetStatus("", false);
        _newClientSecretPlain = null;
        _saving = true;
        try
        {
            var name = _newClientName.Trim();
            var clientId = _newClientId.Trim();

            if (string.IsNullOrWhiteSpace(name) || name.Length > 120)
            {
                SetStatus("Udfyld et app-navn (max 120 tegn).", true);
                return;
            }

            if (!IsValidClientId(clientId))
            {
                SetStatus("Ugyldigt client_id (brug a-z, 0-9, -, _, . og 2–64 tegn).", true);
                return;
            }

            var exists = await Db.ClientApps.AsNoTracking().AnyAsync(c => c.ClientId == clientId);
            if (exists)
            {
                SetStatus("client_id findes allerede — vælg et andet.", true);
                return;
            }

            var newId = Guid.NewGuid();
            string? secretHash = null;
            if (!_newIsPublic)
            {
                var plain = GenerateSecret(48);
                secretHash = BCrypt.Net.BCrypt.HashPassword(plain);
                _newClientSecretPlain = plain;
            }

            Db.ClientApps.Add(new ClientApp
            {
                Id = newId,
                Name = name,
                ClientId = clientId,
                IsActive = _newIsActive,
                IsPublic = _newIsPublic,
                RequirePkce = _newRequirePkce,
                ClientSecretHash = secretHash,
                AllowedScopes = "openid profile email offline_access",
                CreatedAt = DateTime.UtcNow,
            });
            await Db.SaveChangesAsync();

            _newClientName = "";
            _newClientId = "";
            _newClientKind = ClientKind.Spa;
            _newIsActive = true;
            _clientIdWasAuto = true;

            _selectedClientId = newId.ToString();
            _showCreate = false;
            _activeTab = ClientTab.Redirects;
            SetStatus("Klient oprettet — tilføj mindst én redirect URI.", false);
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveClientSettingsAsync()
    {
        SetStatus("", false);
        _rotatedSecretPlain = null;
        if (_selected is null)
            return;

        _saving = true;
        try
        {
            var tracked = await Db.ClientApps.FirstOrDefaultAsync(c => c.Id == _selected.Id);
            if (tracked is null)
                return;

            var name = (_editName ?? "").Trim();
            var clientId = (_editClientId ?? "").Trim();
            if (string.IsNullOrWhiteSpace(name) || name.Length > 120)
            {
                SetStatus("Udfyld et app-navn (max 120 tegn).", true);
                return;
            }

            if (!IsValidClientId(clientId))
            {
                SetStatus("Ugyldigt client_id (brug a-z, 0-9, -, _, . og 2–64 tegn).", true);
                return;
            }

            var existingWithClientId = await Db.ClientApps
                .AsNoTracking()
                .AnyAsync(c => c.Id != tracked.Id && c.ClientId == clientId);
            if (existingWithClientId)
            {
                SetStatus("client_id findes allerede — vælg et andet.", true);
                return;
            }

            tracked.Name = name;
            tracked.ClientId = clientId;
            tracked.IsActive = _editIsActive;
            tracked.IsPublic = _editIsPublic;
            tracked.RequirePkce = _editRequirePkce;
            tracked.AllowedScopes = string.IsNullOrWhiteSpace(_editAllowedScopes) ? null : _editAllowedScopes.Trim();
            tracked.LoginThemeId = LoginThemeCatalog.NormalizeStored(
                string.IsNullOrWhiteSpace(_editLoginThemeId) ? null : _editLoginThemeId);

            if (_editUseAllLoginMethods)
            {
                tracked.AllowedLoginMethods = null;
            }
            else
            {
                var normalized = ClientLoginMethodCatalog.NormalizeStored(_editLoginMethods);
                if (normalized is null)
                {
                    SetStatus("Vælg mindst én login-metode, eller brug «Alle aktiverede metoder».", true);
                    return;
                }

                tracked.AllowedLoginMethods = normalized;
            }

            tracked.RequiredLinkedProviders = ClientLoginMethodCatalog.NormalizeRequiredLinked(_editRequiredLinkedProviders);

            if (tracked.IsPublic)
                tracked.ClientSecretHash = null;

            await Db.SaveChangesAsync();
            SetStatus("Indstillinger gemt.", false);
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteClientAsync()
    {
        SetStatus("", false);
        _rotatedSecretPlain = null;
        if (_selected is null)
            return;

        var ok = await Js.InvokeAsync<bool>(
            "confirm",
            $"Vil du slette klienten '{_selected.Name}' ({_selected.ClientId})? Dette kan ikke fortrydes.");
        if (!ok)
            return;

        _saving = true;
        try
        {
            var tracked = await Db.ClientApps
                .Include(c => c.RedirectUris)
                .FirstOrDefaultAsync(c => c.Id == _selected.Id);
            if (tracked is null)
                return;

            Db.ClientApps.Remove(tracked);
            await Db.SaveChangesAsync();

            _selectedClientId = null;
            _selected = null;
            _newRedirectUri = "";
            _showCreate = false;
            SetStatus("Klient slettet.", false);
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task RotateClientSecretAsync()
    {
        SetStatus("", false);
        _rotatedSecretPlain = null;

        if (_selected is null)
            return;

        if (_editIsPublic)
        {
            SetStatus("Public klient har ikke client secret.", true);
            return;
        }

        _saving = true;
        try
        {
            var tracked = await Db.ClientApps.FirstOrDefaultAsync(c => c.Id == _selected.Id);
            if (tracked is null)
                return;

            var plain = GenerateSecret(48);
            tracked.ClientSecretHash = BCrypt.Net.BCrypt.HashPassword(plain);
            await Db.SaveChangesAsync();

            _rotatedSecretPlain = plain;
            SetStatus("Secret roteret — gem det nye secret nu.", false);
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private bool TryValidateRedirectUri(string raw, out Uri uri, out string error)
    {
        error = "";
        uri = null!;
        raw = (raw ?? "").Trim();
        if (raw.Length == 0)
        {
            error = "Udfyld en redirect URI.";
            return false;
        }

        if (!Uri.TryCreate(raw, UriKind.Absolute, out var parsed) || parsed is null)
        {
            error = "Ugyldig URI (skal være absolut, fx https://…).";
            return false;
        }
        uri = parsed;

        if (uri.Scheme != Uri.UriSchemeHttps && uri.Scheme != Uri.UriSchemeHttp)
        {
            error = "Kun http/https er tilladt.";
            return false;
        }

        var isLocalHttp = uri.Scheme == Uri.UriSchemeHttp &&
                          (string.Equals(uri.Host, "localhost", StringComparison.OrdinalIgnoreCase)
                           || uri.Host == "127.0.0.1");
        if (!Env.IsDevelopment() && !Env.IsEnvironment("Testing") && uri.Scheme != Uri.UriSchemeHttps)
        {
            if (!isLocalHttp)
            {
                error = "I produktion skal redirect URI bruge https.";
                return false;
            }
        }

        return true;
    }

    private async Task AddRedirectUriAsync()
    {
        if (_selected is null)
            return;

        _saving = true;
        try
        {
            if (!TryValidateRedirectUri(_newRedirectUri, out var uri, out var err))
            {
                SetStatus(err, true);
                return;
            }

            var normalized = uri.ToString();

            var exists = await Db.ClientAppRedirectUris
                .AsNoTracking()
                .AnyAsync(r => r.ClientAppId == _selected.Id && r.Uri == normalized);
            if (exists)
            {
                SetStatus("URI findes allerede på klienten.", true);
                return;
            }

            Db.ClientAppRedirectUris.Add(new ClientAppRedirectUri
            {
                Id = Guid.NewGuid(),
                ClientAppId = _selected.Id,
                Uri = normalized,
            });
            await Db.SaveChangesAsync();

            _newRedirectUri = "";
            SetStatus("Redirect URI tilføjet.", false);
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task RemoveRedirectUriAsync(Guid redirectUriId)
    {
        if (_selected is null)
            return;

        _saving = true;
        try
        {
            var row = await Db.ClientAppRedirectUris.FirstOrDefaultAsync(r => r.Id == redirectUriId && r.ClientAppId == _selected.Id);
            if (row is null)
                return;

            Db.ClientAppRedirectUris.Remove(row);
            await Db.SaveChangesAsync();

            SetStatus("Redirect URI fjernet.", false);
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
        }
    }
}
