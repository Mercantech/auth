@page "/Admin/Clients"
@attribute [Authorize(Roles = "Admin")]
@inject AuthDbContext Db
@inject IWebHostEnvironment Env
@using Auth.API.Models.Entities
@using Microsoft.EntityFrameworkCore

<PageTitle>Klienter (admin)</PageTitle>

<div class="merc-page">
<h1>Klienter</h1>

@if (_clients is null)
{
    <p>Henter…</p>
}
else
{
    <div class="card">
        <h2>Opret ny klient</h2>
        <div class="field">
            <label><strong>Navn</strong></label>
            <input class="input" placeholder="Min app" @bind="_newClientName" />
        </div>
        <div class="field">
            <label><strong>Client ID</strong></label>
            <input class="input" placeholder="fx my-app" @bind="_newClientId" />
            <div class="muted">Bruges som <code>client_id</code> i OAuth/OIDC.</div>
        </div>
        <div class="field">
            <label><strong>Type</strong></label>
            <label class="muted"><input type="checkbox" @bind="_newIsPublic" /> Public klient (ingen secret, PKCE anbefales)</label>
        </div>
        <div class="field">
            <label class="muted"><input type="checkbox" @bind="_newRequirePkce" /> Kræv PKCE (S256)</label>
        </div>
        <div class="field">
            <label class="muted"><input type="checkbox" @bind="_newIsActive" /> Aktiv</label>
        </div>
        <button type="button" class="btn" @onclick="CreateClientAsync">Opret klient</button>

        @if (!string.IsNullOrWhiteSpace(_newClientSecretPlain))
        {
            <div class="divider"></div>
            <p class="status-warn"><strong>Client secret (vises kun nu):</strong> <code>@_newClientSecretPlain</code></p>
        }
    </div>

    <div class="card">
        <h2>Vælg klient</h2>
        <div class="field">
            <label for="clientSelect"><strong>Klient</strong></label>
            <select id="clientSelect" class="input" value="@_selectedClientId" @onchange="OnClientChanged">
                <option value="">— vælg —</option>
                @foreach (var c in _clients.OrderBy(x => x.Name))
                {
                    <option value="@c.Id">@c.Name (@c.ClientId)</option>
                }
            </select>
        </div>
        @if (!string.IsNullOrWhiteSpace(_status))
        {
            <p class="@(_statusIsError ? "status-warn" : "status-badge status-in")">@_status</p>
        }
    </div>

    @if (_selected is not null)
    {
        <div class="card">
            <h2>Indstillinger</h2>
            <div class="field">
                <label class="muted"><input type="checkbox" @bind="_editIsActive" /> Aktiv</label>
            </div>
            <div class="field">
                <label class="muted"><input type="checkbox" @bind="_editIsPublic" /> Public klient</label>
            </div>
            <div class="field">
                <label class="muted"><input type="checkbox" @bind="_editRequirePkce" /> Kræv PKCE (S256)</label>
            </div>
            <div class="field">
                <label><strong>Tilladte scopes</strong> (valgfri)</label>
                <input class="input" placeholder="openid profile email offline_access" @bind="_editAllowedScopes" />
                <div class="muted">Space-separeret liste. Bruges til at dokumentere/afgrænse scopes pr. klient.</div>
            </div>

            <button type="button" class="btn" @onclick="SaveClientSettingsAsync">Gem</button>

            @if (!_editIsPublic)
            {
                <div class="divider"></div>
                <button type="button" class="btn btn-secondary" @onclick="RotateClientSecretAsync">Rotér client secret</button>
                @if (!string.IsNullOrWhiteSpace(_rotatedSecretPlain))
                {
                    <p class="status-warn"><strong>Nyt client secret (vises kun nu):</strong> <code>@_rotatedSecretPlain</code></p>
                }
            }
        </div>

        <div class="card">
            <h2>Redirect URI whitelist</h2>
            <p class="muted">
                OAuth2 kræver præcist match på <code>redirect_uri</code> (https/http, host og path).
            </p>

            <table class="table table-sm">
                <thead>
                <tr>
                    <th>URI</th>
                    <th style="width: 1%"></th>
                </tr>
                </thead>
                <tbody>
                @if (_selected.RedirectUris.Count == 0)
                {
                    <tr><td colspan="2">Ingen redirect-URI’er endnu.</td></tr>
                }
                else
                {
                    @foreach (var r in _selected.RedirectUris.OrderBy(x => x.Uri, StringComparer.Ordinal))
                    {
                        <tr>
                            <td><code>@r.Uri</code></td>
                            <td>
                                <button type="button" class="btn btn-secondary" @onclick="() => RemoveRedirectUriAsync(r.Id)">
                                    Fjern
                                </button>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>

            <div class="divider"></div>

            <h3>Tilføj redirect URI</h3>
            <div class="field">
                <label for="newUri"><strong>Ny URI</strong></label>
                <input id="newUri" class="input" placeholder="https://auth-spa.mercantec.tech/callback.html" @bind="_newRedirectUri" />
                <div class="muted">
                    Produktion: brug <strong>https</strong>. Dev kan være <code>http://localhost:...</code>.
                </div>
            </div>
            <button type="button" class="btn" @onclick="AddRedirectUriAsync">Tilføj</button>
        </div>
    }
}
</div>

@code {
    private List<ClientApp>? _clients;
    private ClientApp? _selected;
    private string? _selectedClientId;
    private string _newRedirectUri = "";
    private string? _status;
    private bool _statusIsError;

    private string _newClientName = "";
    private string _newClientId = "";
    private bool _newIsPublic = true;
    private bool _newRequirePkce = true;
    private bool _newIsActive = true;
    private string? _newClientSecretPlain;

    private bool _editIsActive;
    private bool _editIsPublic;
    private bool _editRequirePkce;
    private string _editAllowedScopes = "";
    private string? _rotatedSecretPlain;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _clients = await Db.ClientApps
            .AsNoTracking()
            .Include(c => c.RedirectUris)
            .OrderBy(c => c.Name)
            .ToListAsync();

        _selected = null;
        if (!string.IsNullOrWhiteSpace(_selectedClientId) && Guid.TryParse(_selectedClientId, out var id))
            _selected = _clients.FirstOrDefault(c => c.Id == id);

        if (_selected is not null)
        {
            _editIsActive = _selected.IsActive;
            _editIsPublic = _selected.IsPublic;
            _editRequirePkce = _selected.RequirePkce;
            _editAllowedScopes = _selected.AllowedScopes ?? "";
            _rotatedSecretPlain = null;
        }
    }

    private Task OnClientChanged(ChangeEventArgs e)
    {
        _selectedClientId = e.Value?.ToString();
        _status = null;
        _statusIsError = false;
        _newRedirectUri = "";
        _rotatedSecretPlain = null;
        return ReloadAsync();
    }

    private static string GenerateSecret(int bytes = 32)
    {
        var b = System.Security.Cryptography.RandomNumberGenerator.GetBytes(bytes);
        return Convert.ToBase64String(b).TrimEnd('=').Replace('+', '-').Replace('/', '_');
    }

    private static bool IsValidClientId(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return false;
        value = value.Trim();
        if (value.Length < 2 || value.Length > 64)
            return false;
        foreach (var ch in value)
        {
            if (!(char.IsLetterOrDigit(ch) || ch is '-' or '_' or '.'))
                return false;
        }
        return true;
    }

    private async Task CreateClientAsync()
    {
        _status = null;
        _statusIsError = false;
        _newClientSecretPlain = null;

        var name = _newClientName.Trim();
        var clientId = _newClientId.Trim();

        if (string.IsNullOrWhiteSpace(name) || name.Length > 120)
        {
            _status = "Udfyld et navn (max 120 tegn).";
            _statusIsError = true;
            return;
        }

        if (!IsValidClientId(clientId))
        {
            _status = "Ugyldigt client_id (brug a-z, 0-9, -, _, . og 2-64 tegn).";
            _statusIsError = true;
            return;
        }

        var exists = await Db.ClientApps.AsNoTracking().AnyAsync(c => c.ClientId == clientId);
        if (exists)
        {
            _status = "client_id findes allerede.";
            _statusIsError = true;
            return;
        }

        string? secretHash = null;
        if (!_newIsPublic)
        {
            var plain = GenerateSecret(48);
            secretHash = BCrypt.Net.BCrypt.HashPassword(plain);
            _newClientSecretPlain = plain;
        }

        Db.ClientApps.Add(new ClientApp
        {
            Id = Guid.NewGuid(),
            Name = name,
            ClientId = clientId,
            IsActive = _newIsActive,
            IsPublic = _newIsPublic,
            RequirePkce = _newRequirePkce,
            ClientSecretHash = secretHash,
            AllowedScopes = "openid profile email offline_access",
            CreatedAt = DateTime.UtcNow,
        });
        await Db.SaveChangesAsync();

        _newClientName = "";
        _newClientId = "";
        _newIsPublic = true;
        _newRequirePkce = true;
        _newIsActive = true;

        _status = "Klient oprettet.";
        await ReloadAsync();
    }

    private async Task SaveClientSettingsAsync()
    {
        _status = null;
        _statusIsError = false;
        _rotatedSecretPlain = null;

        if (_selected is null)
            return;

        var id = _selected.Id;
        var tracked = await Db.ClientApps.FirstOrDefaultAsync(c => c.Id == id);
        if (tracked is null)
            return;

        tracked.IsActive = _editIsActive;
        tracked.IsPublic = _editIsPublic;
        tracked.RequirePkce = _editRequirePkce;
        tracked.AllowedScopes = string.IsNullOrWhiteSpace(_editAllowedScopes) ? null : _editAllowedScopes.Trim();

        if (tracked.IsPublic)
            tracked.ClientSecretHash = null;

        await Db.SaveChangesAsync();
        _status = "Gemt.";
        await ReloadAsync();
    }

    private async Task RotateClientSecretAsync()
    {
        _status = null;
        _statusIsError = false;
        _rotatedSecretPlain = null;

        if (_selected is null)
            return;

        var tracked = await Db.ClientApps.FirstOrDefaultAsync(c => c.Id == _selected.Id);
        if (tracked is null)
            return;

        if (tracked.IsPublic)
        {
            _status = "Public klient har ikke secret.";
            _statusIsError = true;
            return;
        }

        var plain = GenerateSecret(48);
        tracked.ClientSecretHash = BCrypt.Net.BCrypt.HashPassword(plain);
        await Db.SaveChangesAsync();

        _rotatedSecretPlain = plain;
        _status = "Secret roteret.";
        await ReloadAsync();
    }

    private bool TryValidateRedirectUri(string raw, out Uri uri, out string error)
    {
        error = "";
        uri = null!;
        raw = (raw ?? "").Trim();
        if (raw.Length == 0)
        {
            error = "Udfyld en redirect URI.";
            return false;
        }

        if (!Uri.TryCreate(raw, UriKind.Absolute, out var parsed) || parsed is null)
        {
            error = "Ugyldig URI (skal være absolut, fx https://...).";
            return false;
        }
        uri = parsed;

        if (uri.Scheme != Uri.UriSchemeHttps && uri.Scheme != Uri.UriSchemeHttp)
        {
            error = "Kun http/https er tilladt.";
            return false;
        }

        var isLocalHttp = uri.Scheme == Uri.UriSchemeHttp &&
                          (string.Equals(uri.Host, "localhost", StringComparison.OrdinalIgnoreCase)
                           || uri.Host == "127.0.0.1");
        if (!Env.IsDevelopment() && !Env.IsEnvironment("Testing") && uri.Scheme != Uri.UriSchemeHttps)
        {
            if (!isLocalHttp)
            {
                error = "I produktion skal redirect URI bruge https.";
                return false;
            }
        }

        return true;
    }

    private async Task AddRedirectUriAsync()
    {
        _status = null;
        _statusIsError = false;

        if (_selected is null || _clients is null)
            return;

        if (!TryValidateRedirectUri(_newRedirectUri, out var uri, out var err))
        {
            _status = err;
            _statusIsError = true;
            return;
        }

        var normalized = uri.ToString();

        var exists = await Db.ClientAppRedirectUris
            .AsNoTracking()
            .AnyAsync(r => r.ClientAppId == _selected.Id && r.Uri == normalized);
        if (exists)
        {
            _status = "URI findes allerede på klienten.";
            _statusIsError = true;
            return;
        }

        Db.ClientAppRedirectUris.Add(new ClientAppRedirectUri
        {
            Id = Guid.NewGuid(),
            ClientAppId = _selected.Id,
            Uri = normalized,
        });
        await Db.SaveChangesAsync();

        _newRedirectUri = "";
        _status = "Tilføjet.";
        await ReloadAsync();
    }

    private async Task RemoveRedirectUriAsync(Guid redirectUriId)
    {
        _status = null;
        _statusIsError = false;

        if (_selected is null)
            return;

        var row = await Db.ClientAppRedirectUris.FirstOrDefaultAsync(r => r.Id == redirectUriId && r.ClientAppId == _selected.Id);
        if (row is null)
            return;

        Db.ClientAppRedirectUris.Remove(row);
        await Db.SaveChangesAsync();

        _status = "Fjernet.";
        await ReloadAsync();
    }
}

