@page "/Admin/Dokploy"
@attribute [Authorize(Roles = "Admin")]
@using System.Security.Claims
@using Auth.API.Models.Entities
@using Auth.API.Options
@using Auth.API.Services.Dokploy
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Options
@inject AuthDbContext Db
@inject IDokployAclSyncService AclSync
@inject IDokployAccessRequestService AccessRequests
@inject IDokployApiClient Api
@inject IOptions<DokployOptions> DokployOptions
@inject AuthenticationStateProvider AuthState

<PageTitle>Dokploy (admin)</PageTitle>

<div class="merc-page merc-dokploy">
    <header class="merc-users__header merc-dokploy__header">
        <div>
            <h1>Dokploy</h1>
            <p class="merc-users__lead">
                Godkend adgangsanmodninger, og styr projekter + rettigheder pr. bruger.
                Kun projektnavne vises — ikke IDs.
            </p>
        </div>
        <div class="merc-dokploy__header-actions">
            <a class="merc-btn merc-btn--ghost" href="/dokploy">Brugerside</a>
            <button type="button" class="merc-btn merc-btn--primary" @onclick="SyncNowAsync" disabled="@(_busy || !_enabled)">
                @(_busy ? "Synker…" : "Sync nu")
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="merc-alert @(_statusIsError ? "merc-alert--error" : "merc-alert--ok")" role="status">
            @_status
        </div>
    }

    <section class="merc-panel" aria-labelledby="dokploy-status">
        <h2 id="dokploy-status" class="merc-users__panel-title">Status</h2>
        <p class="merc-hint merc-hint--block">
            Enabled: <strong>@(_enabled ? "ja" : "nej")</strong>
            · Interval: <strong>@_interval min</strong>
            @if (_lastResult is not null)
            {
                <text>
                    · Sidste sync: linked=@_lastResult.LinkedUsers, pushed=@_lastResult.Pushed,
                    pulled=@_lastResult.Pulled, errors=@_lastResult.Errors
                    (@_lastResult.RanAtUtc.LocalDateTime.ToString("g"))
                </text>
            }
        </p>
        @if (!_enabled)
        {
            <p class="merc-hint merc-hint--block">Sæt <code>Dokploy__Enabled=true</code> og <code>Dokploy__ApiKey</code> for at aktivere.</p>
        }
    </section>

    <section class="merc-panel" aria-labelledby="pending-heading">
        <h2 id="pending-heading" class="merc-users__panel-title">
            Afventende anmodninger
            @if (_pending is { Count: > 0 })
            {
                <span class="merc-badge">@_pending.Count</span>
            }
        </h2>
        @if (_pending is null)
        {
            <p class="merc-users__loading">Henter…</p>
        }
        else if (_pending.Count == 0)
        {
            <p class="merc-hint merc-hint--block">Ingen afventende anmodninger.</p>
        }
        else
        {
            <div class="merc-dokploy__pending-list">
                @foreach (var req in _pending)
                {
                    <article class="merc-dokploy__pending-card">
                        <div class="merc-dokploy__card-top">
                            <div>
                                <h3 class="merc-dokploy__name">@req.User.DisplayName</h3>
                                <p class="merc-dokploy__email">@(req.User.Email ?? "—")</p>
                                <p class="merc-hint">Sendt @req.CreatedAtUtc.ToLocalTime().ToString("g")</p>
                            </div>
                        </div>
                        <p class="merc-dokploy__history-body">
                            <strong>Projekter:</strong>
                            @(req.Projects.Count == 0
                                ? "—"
                                : string.Join(", ", req.Projects.Select(p => p.ProjectName ?? "Projekt")))
                        </p>
                        <p class="merc-dokploy__history-body">
                            <strong>Rettigheder:</strong> @DescribeCaps(req)
                        </p>
                        @if (!string.IsNullOrWhiteSpace(req.Message))
                        {
                            <p class="merc-hint">“@req.Message”</p>
                        }
                        <label class="merc-dokploy__field-label" for="note-@req.Id">Note (valgfri)</label>
                        <input id="note-@req.Id" class="merc-input" @bind="_reviewNotes[req.Id]" />
                        <div class="merc-dokploy__card-actions">
                            <button type="button" class="merc-btn merc-btn--ghost" disabled="@_busy"
                                    @onclick="() => RejectAsync(req.Id)">
                                Afvis
                            </button>
                            <button type="button" class="merc-btn merc-btn--primary" disabled="@_busy"
                                    @onclick="() => ApproveAsync(req.Id)">
                                Godkend
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    @if (_rows is null)
    {
        <p class="merc-users__loading">Henter…</p>
    }
    else if (_rows.Count == 0)
    {
        <p class="merc-hint merc-hint--block">Ingen brugere endnu.</p>
    }
    else
    {
        <div class="merc-dokploy__grid">
            @foreach (var r in _rows)
            {
                var open = _openDropdownUserId == r.Id;
                var selectedCount = r.SelectedProjectIds.Count;
                <article class="merc-panel merc-dokploy__card">
                    <div class="merc-dokploy__card-top">
                        <div>
                            <h2 class="merc-dokploy__name">@r.DisplayName</h2>
                            <p class="merc-dokploy__email">@(r.Email ?? "—")</p>
                        </div>
                        <div class="merc-dokploy__badges">
                            @if (r.IsProvisioned)
                            {
                                <span class="merc-badge merc-badge--public">Dokploy-konto</span>
                            }
                            else if (r.HasLink)
                            {
                                <span class="merc-badge merc-badge--muted">afventer</span>
                            }
                            else
                            {
                                <span class="merc-badge merc-badge--muted">ingen Dokploy-konto</span>
                            }
                            @if (r.AclDirty)
                            {
                                <span class="merc-badge">ikke synket</span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(r.LastError))
                    {
                        <p class="merc-hint merc-hint--block">@r.LastError</p>
                    }

                    <label class="merc-dokploy__field-label" for="dokploy-projects-@r.Id">Projekter</label>
                    <div class="merc-dokploy__dropdown @(open ? "merc-dokploy__dropdown--open" : null)">
                        <button type="button"
                                id="dokploy-projects-@r.Id"
                                class="merc-dokploy__dropdown-trigger merc-input"
                                disabled="@(!_enabled || _projects is null || _projects.Count == 0)"
                                aria-expanded="@open"
                                aria-haspopup="listbox"
                                @onclick="() => ToggleDropdown(r.Id)">
                            <span>
                                @if (_projects is null || _projects.Count == 0)
                                {
                                    <text>Ingen projekter hentet</text>
                                }
                                else if (selectedCount == 0)
                                {
                                    <text>Vælg projekter…</text>
                                }
                                else
                                {
                                    <text>@selectedCount projekt@(selectedCount == 1 ? "" : "er") valgt</text>
                                }
                            </span>
                            <span class="merc-dokploy__chevron" aria-hidden="true">▾</span>
                        </button>

                        @if (open && _projects is { Count: > 0 })
                        {
                            <div class="merc-dokploy__dropdown-panel" role="listbox" aria-multiselectable="true">
                                <input class="merc-input merc-dokploy__search"
                                       type="search"
                                       placeholder="Søg på projektnavn…"
                                       value="@_projectFilter"
                                       @oninput="OnFilterInput"
                                       @onclick:stopPropagation="true" />
                                <div class="merc-dokploy__options">
                                    @foreach (var p in FilteredProjects())
                                    {
                                        var selected = r.SelectedProjectIds.Contains(p.Id);
                                        <label class="merc-dokploy__option merc-check">
                                            <input type="checkbox"
                                                   checked="@selected"
                                                   @onchange="e => ToggleProject(r, p.Id, (bool)(e.Value ?? false))" />
                                            <span class="merc-dokploy__option-name">@p.DisplayName</span>
                                        </label>
                                    }
                                </div>
                                @if (FilteredProjects().Count == 0)
                                {
                                    <p class="merc-hint merc-dokploy__empty">Ingen match.</p>
                                }
                            </div>
                        }
                    </div>

                    @if (selectedCount > 0)
                    {
                        <ul class="merc-dokploy__chips" aria-label="Valgte projekter">
                            @foreach (var id in r.SelectedProjectIds.OrderBy(x => ProjectLabel(r, x), StringComparer.OrdinalIgnoreCase))
                            {
                                <li>
                                    <button type="button"
                                            class="merc-dokploy__chip"
                                            title="Fjern"
                                            @onclick="() => ToggleProject(r, id, false)">
                                        @ProjectLabel(r, id)
                                        <span aria-hidden="true">×</span>
                                    </button>
                                </li>
                            }
                        </ul>
                    }

                    <div class="merc-dokploy__caps">
                        <p class="merc-dokploy__field-label">Rettigheder i Dokploy</p>
                        <div class="merc-dokploy__caps-grid">
                            @foreach (var cap in CapabilityDefs)
                            {
                                <label class="merc-check merc-dokploy__cap">
                                    <input type="checkbox"
                                           checked="@GetCap(r, cap.Key)"
                                           @onchange="e => SetCap(r, cap.Key, (bool)(e.Value ?? false))" />
                                    <span>@cap.Label</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="merc-dokploy__card-actions">
                        <span class="merc-hint">
                            @if (r.AclSyncedAtUtc is not null)
                            {
                                <text>Synket @r.AclSyncedAtUtc.Value.ToLocalTime().ToString("g")</text>
                            }
                            else
                            {
                                <text>Ikke synket endnu</text>
                            }
                        </span>
                        <button type="button"
                                class="merc-btn merc-btn--primary"
                                disabled="@(_busy || !_enabled || string.IsNullOrWhiteSpace(r.Email))"
                                @onclick="() => SaveAsync(r)">
                            Gem permissions
                        </button>
                    </div>
                </article>
            }
        </div>
    }
</div>

@code {
    private bool _enabled;
    private int _interval;
    private bool _busy;
    private string? _status;
    private bool _statusIsError;
    private List<UserRow>? _rows;
    private List<DokployAccessRequest>? _pending;
    private Dictionary<Guid, string> _reviewNotes = new();
    private Guid _adminUserId;
    private List<ProjectOption>? _projects;
    private DokployAclSyncResult? _lastResult;
    private Guid? _openDropdownUserId;
    private string _projectFilter = "";

    protected override async Task OnInitializedAsync()
    {
        var opts = DokployOptions.Value;
        _enabled = opts.Enabled && !string.IsNullOrWhiteSpace(opts.ApiKey);
        _interval = Math.Max(1, opts.AclSyncIntervalMinutes);
        var auth = await AuthState.GetAuthenticationStateAsync();
        Guid.TryParse(auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _adminUserId);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _pending = (await AccessRequests.ListPendingAsync()).ToList();
        foreach (var p in _pending)
            _reviewNotes.TryAdd(p.Id, "");

        _projects = [];
        if (_enabled)
        {
            try
            {
                var remote = await Api.ListProjectsForPermissionsAsync();
                _projects = remote
                    .Where(p => !string.IsNullOrWhiteSpace(p.ResolvedId))
                    .Select(p => new ProjectOption(p.ResolvedId, CleanProjectName(p.Name, p.ResolvedId)))
                    .DistinctBy(p => p.Id)
                    .OrderBy(p => p.DisplayName, StringComparer.OrdinalIgnoreCase)
                    .ToList();
            }
            catch (Exception ex)
            {
                _status = $"Kunne ikke hente projekter: {ex.Message}";
                _statusIsError = true;
            }
        }

        var users = await Db.Users
            .AsNoTracking()
            .OrderBy(u => u.DisplayName)
            .Select(u => new
            {
                u.Id,
                u.DisplayName,
                u.Email,
                Link = u.DokployLink,
                Grants = u.DokployProjectGrants
                    .Select(g => new { g.DokployProjectId, g.ProjectName })
                    .ToList(),
            })
            .ToListAsync();

        _rows = users.Select(u =>
        {
            var caps = u.Link is null
                ? new DokployCapabilityFlags()
                : DokployCapabilityFlags.FromLink(u.Link);
            return new UserRow
            {
                Id = u.Id,
                DisplayName = u.DisplayName,
                Email = u.Email,
                HasLink = u.Link is not null,
                IsProvisioned = u.Link?.IsProvisioned == true,
                LastError = u.Link?.LastError,
                AclDirty = u.Link?.AclDirty == true,
                AclSyncedAtUtc = u.Link?.AclSyncedAtUtc,
                SelectedProjectIds = u.Grants.Select(g => g.DokployProjectId).ToHashSet(StringComparer.Ordinal),
                GrantNames = u.Grants
                    .Where(g => !string.IsNullOrWhiteSpace(g.ProjectName))
                    .ToDictionary(g => g.DokployProjectId, g => g.ProjectName!, StringComparer.Ordinal),
                Caps = caps,
            };
        }).ToList();
    }

    private async Task ApproveAsync(Guid requestId)
    {
        _busy = true;
        try
        {
            _reviewNotes.TryGetValue(requestId, out var note);
            var result = await AccessRequests.ApproveAsync(requestId, _adminUserId, note);
            _status = result.Ok ? "Anmodning godkendt — permissions pushet." : result.Error;
            _statusIsError = !result.Ok;
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RejectAsync(Guid requestId)
    {
        _busy = true;
        try
        {
            _reviewNotes.TryGetValue(requestId, out var note);
            var result = await AccessRequests.RejectAsync(requestId, _adminUserId, note);
            _status = result.Ok ? "Anmodning afvist." : result.Error;
            _statusIsError = !result.Ok;
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private static string DescribeCaps(DokployAccessRequest r)
    {
        var parts = new List<string>();
        if (r.CanCreateProjects) parts.Add("Opret projekter");
        if (r.CanDeleteProjects) parts.Add("Slet projekter");
        if (r.CanCreateServices) parts.Add("Opret services");
        if (r.CanDeleteServices) parts.Add("Slet services");
        if (r.CanCreateEnvironments) parts.Add("Opret env");
        if (r.CanDeleteEnvironments) parts.Add("Slet env");
        if (r.CanAccessToDocker) parts.Add("Docker");
        if (r.CanAccessToTraefikFiles) parts.Add("Traefik");
        if (r.CanAccessToAPI) parts.Add("API");
        if (r.CanAccessToSSHKeys) parts.Add("SSH");
        if (r.CanAccessToGitProviders) parts.Add("Git");
        return parts.Count == 0 ? "—" : string.Join(", ", parts);
    }

    private static readonly (string Key, string Label)[] CapabilityDefs =
    [
        ("CanCreateProjects", "Opret projekter"),
        ("CanDeleteProjects", "Slet projekter"),
        ("CanCreateServices", "Opret services"),
        ("CanDeleteServices", "Slet services"),
        ("CanCreateEnvironments", "Opret environments"),
        ("CanDeleteEnvironments", "Slet environments"),
        ("CanAccessToDocker", "Docker"),
        ("CanAccessToTraefikFiles", "Traefik-filer"),
        ("CanAccessToAPI", "API"),
        ("CanAccessToSSHKeys", "SSH-nøgler"),
        ("CanAccessToGitProviders", "Git-providers"),
    ];

    private static bool GetCap(UserRow row, string key) => key switch
    {
        "CanCreateProjects" => row.Caps.CanCreateProjects,
        "CanCreateServices" => row.Caps.CanCreateServices,
        "CanDeleteProjects" => row.Caps.CanDeleteProjects,
        "CanDeleteServices" => row.Caps.CanDeleteServices,
        "CanAccessToDocker" => row.Caps.CanAccessToDocker,
        "CanAccessToTraefikFiles" => row.Caps.CanAccessToTraefikFiles,
        "CanAccessToAPI" => row.Caps.CanAccessToAPI,
        "CanAccessToSSHKeys" => row.Caps.CanAccessToSSHKeys,
        "CanAccessToGitProviders" => row.Caps.CanAccessToGitProviders,
        "CanDeleteEnvironments" => row.Caps.CanDeleteEnvironments,
        "CanCreateEnvironments" => row.Caps.CanCreateEnvironments,
        _ => false,
    };

    private static void SetCap(UserRow row, string key, bool value)
    {
        switch (key)
        {
            case "CanCreateProjects": row.Caps.CanCreateProjects = value; break;
            case "CanCreateServices": row.Caps.CanCreateServices = value; break;
            case "CanDeleteProjects": row.Caps.CanDeleteProjects = value; break;
            case "CanDeleteServices": row.Caps.CanDeleteServices = value; break;
            case "CanAccessToDocker": row.Caps.CanAccessToDocker = value; break;
            case "CanAccessToTraefikFiles": row.Caps.CanAccessToTraefikFiles = value; break;
            case "CanAccessToAPI": row.Caps.CanAccessToAPI = value; break;
            case "CanAccessToSSHKeys": row.Caps.CanAccessToSSHKeys = value; break;
            case "CanAccessToGitProviders": row.Caps.CanAccessToGitProviders = value; break;
            case "CanDeleteEnvironments": row.Caps.CanDeleteEnvironments = value; break;
            case "CanCreateEnvironments": row.Caps.CanCreateEnvironments = value; break;
        }
    }

    /// <summary>
    /// Hvis API returnerer navn+id klæbet sammen, strip id-suffix så UI kun viser navnet.
    /// </summary>
    private static string CleanProjectName(string? name, string projectId)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "Projekt";

        var trimmed = name.Trim();
        if (!string.IsNullOrWhiteSpace(projectId)
            && trimmed.EndsWith(projectId, StringComparison.Ordinal)
            && trimmed.Length > projectId.Length)
        {
            return trimmed[..^projectId.Length].Trim();
        }

        return trimmed;
    }

    private void ToggleDropdown(Guid userId)
    {
        if (_openDropdownUserId == userId)
        {
            _openDropdownUserId = null;
            _projectFilter = "";
            return;
        }

        _openDropdownUserId = userId;
        _projectFilter = "";
    }

    private void OnFilterInput(ChangeEventArgs e)
        => _projectFilter = e.Value?.ToString() ?? "";

    private IReadOnlyList<ProjectOption> FilteredProjects()
    {
        if (_projects is null || _projects.Count == 0)
            return [];

        if (string.IsNullOrWhiteSpace(_projectFilter))
            return _projects;

        var q = _projectFilter.Trim();
        return _projects
            .Where(p => p.DisplayName.Contains(q, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private string ProjectLabel(UserRow row, string projectId)
    {
        var fromList = _projects?.FirstOrDefault(p => p.Id == projectId);
        if (fromList is not null)
            return fromList.DisplayName;

        if (row.GrantNames.TryGetValue(projectId, out var cached) && !string.IsNullOrWhiteSpace(cached))
            return CleanProjectName(cached, projectId);

        return "Ukendt projekt";
    }

    private void ToggleProject(UserRow row, string projectId, bool on)
    {
        if (on)
            row.SelectedProjectIds.Add(projectId);
        else
            row.SelectedProjectIds.Remove(projectId);
    }

    private async Task SaveAsync(UserRow row)
    {
        _busy = true;
        _status = null;
        try
        {
            var nameById = (_projects ?? []).ToDictionary(p => p.Id, p => (string?)p.DisplayName, StringComparer.Ordinal);
            var projects = row.SelectedProjectIds
                .Select(id => (id, nameById.GetValueOrDefault(id) ?? row.GrantNames.GetValueOrDefault(id)))
                .ToList();
            await AclSync.SavePermissionsAndPushAsync(row.Id, projects, row.Caps);
            _status = $"Permissions gemt for {row.DisplayName}.";
            _statusIsError = false;
            _openDropdownUserId = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _status = ex.Message;
            _statusIsError = true;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SyncNowAsync()
    {
        _busy = true;
        _status = null;
        try
        {
            _lastResult = await AclSync.ReconcileAsync();
            _status = _lastResult.Errors > 0
                ? $"Sync færdig med {_lastResult.Errors} fejl."
                : "Sync færdig.";
            _statusIsError = _lastResult.Errors > 0;
            _openDropdownUserId = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _status = ex.Message;
            _statusIsError = true;
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class UserRow
    {
        public Guid Id { get; init; }
        public string DisplayName { get; init; } = "";
        public string? Email { get; init; }
        public bool HasLink { get; init; }
        public bool IsProvisioned { get; init; }
        public string? LastError { get; init; }
        public bool AclDirty { get; init; }
        public DateTime? AclSyncedAtUtc { get; init; }
        public HashSet<string> SelectedProjectIds { get; init; } = new(StringComparer.Ordinal);
        public Dictionary<string, string> GrantNames { get; init; } = new(StringComparer.Ordinal);
        public DokployCapabilityFlags Caps { get; init; } = new();
    }

    private sealed record ProjectOption(string Id, string DisplayName);
}
