@page "/Account/Login"
@layout AuthLayout
@using Microsoft.AspNetCore.Antiforgery
@inject IHttpContextAccessor HttpContextAccessor
@inject IAntiforgery Antiforgery
@inject IConfiguration Configuration
@inject IOptions<AuthOptions> AuthOptions

<PageTitle>Log ind</PageTitle>

<div class="auth-card">
    <div class="auth-brand">
        <div class="auth-brand__mark" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 4L6 9v14l10 5 10-5V9L16 4z" stroke="white" stroke-width="1.8" stroke-linejoin="round" fill="rgba(255,255,255,0.15)" />
                <path d="M16 11v10M11 13.5l10 5M21 13.5l-10 5" stroke="white" stroke-width="1.5" stroke-linecap="round" />
            </svg>
        </div>
        <div>
            <h1 class="auth-brand__title">Mercantec Auth</h1>
            <p class="auth-brand__subtitle">Sikker adgang til dine Mercantec-apps</p>
        </div>
    </div>

    <h2 class="auth-headline">Log ind</h2>
    <p class="auth-lead">@(LocalLoginEnabled
        ? "Vælg en udbyder eller brug din Mercantec e-mail — ét sted for hele skolen."
        : "Vælg en udbyder nedenfor — e-mail og adgangskode er slået fra i denne installation.")</p>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="auth-alert" role="alert">@ErrorMessage</div>
    }

    @if (!AnyOAuthProvider && !LocalLoginEnabled)
    {
        <div class="auth-alert" role="alert">Ingen login-metode er aktiveret (hverken OAuth eller e-mail). Tjek serverkonfiguration.</div>
    }

        @if (AnyOAuthProvider)
        {
            var extReturn = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
        <div class="auth-providers">
            @if (GoogleEnabled)
            {
                <a class="auth-provider auth-provider--google" href="@ChallengeUrl("google", extReturn)">
                    <span class="auth-provider__icon" aria-hidden="true">
                        <svg width="22" height="22" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        </svg>
                    </span>
                    <span class="auth-provider__body">
                        <span class="auth-provider__name">Google</span>
                        <span class="auth-provider__hint">Fortsæt med Google-konto</span>
                    </span>
                    <svg class="auth-provider__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
                </a>
            }
            @if (MicrosoftEnabled)
            {
                <a class="auth-provider auth-provider--microsoft" href="@ChallengeUrl("microsoft", extReturn, "work")">
                    <span class="auth-provider__icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 23 23" xmlns="http://www.w3.org/2000/svg">
                            <path fill="#f25022" d="M1 1h10v10H1z" />
                            <path fill="#00a4ef" d="M12 1h10v10H12z" />
                            <path fill="#7fba00" d="M1 12h10v10H1z" />
                            <path fill="#ffb900" d="M12 12h10v10H12z" />
                        </svg>
                    </span>
                    <span class="auth-provider__body">
                        <span class="auth-provider__name">Microsoft 365</span>
                        <span class="auth-provider__hint">Arbejds- eller skolekonto (Azure AD)</span>
                    </span>
                    <svg class="auth-provider__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
                </a>
                <div class="auth-provider auth-provider--disabled" title="Kommer snart" aria-disabled="true">
                    <span class="auth-provider__icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 23 23" xmlns="http://www.w3.org/2000/svg" opacity="0.7">
                            <path fill="#f25022" d="M1 1h10v10H1z" />
                            <path fill="#00a4ef" d="M12 1h10v10H12z" />
                            <path fill="#7fba00" d="M1 12h10v10H1z" />
                            <path fill="#ffb900" d="M12 12h10v10H12z" />
                        </svg>
                    </span>
                    <span class="auth-provider__body">
                        <span class="auth-provider__name">Microsoft — skolemail</span>
                        <span class="auth-provider__hint">Aktiveres snart · UNI•Login-lignende flow</span>
                    </span>
                </div>
            }
            @if (GitHubEnabled)
            {
                <a class="auth-provider auth-provider--github" href="@ChallengeUrl("github", extReturn)">
                    <span class="auth-provider__icon" aria-hidden="true">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="#f0f4fc" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                        </svg>
                    </span>
                    <span class="auth-provider__body">
                        <span class="auth-provider__name">GitHub</span>
                        <span class="auth-provider__hint">Udviklere og open source</span>
                    </span>
                    <svg class="auth-provider__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
                </a>
            }
            @if (DiscordEnabled)
            {
                <a class="auth-provider auth-provider--discord" href="@ChallengeUrl("discord", extReturn)">
                    <span class="auth-provider__icon" aria-hidden="true">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="#f0f4fc" xmlns="http://www.w3.org/2000/svg">
                            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
                        </svg>
                    </span>
                    <span class="auth-provider__body">
                        <span class="auth-provider__name">Discord</span>
                        <span class="auth-provider__hint">Communities og studiegrupper</span>
                    </span>
                    <svg class="auth-provider__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
                </a>
            }
        </div>
    }

    @if (AnyOAuthProvider && LocalLoginEnabled)
    {
        <div class="auth-divider"><span>eller</span></div>
    }

    @if (LocalLoginEnabled && HttpContextAccessor.HttpContext is { } ctx)
    {
        var tokens = Antiforgery.GetAndStoreTokens(ctx);
        <form method="post" action="/signin">
            <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="auth-field">
                <label class="auth-label" for="email">E-mail</label>
                <input id="email" name="email" class="auth-input" type="email" autocomplete="username" placeholder="dig@eksempel.dk" required />
            </div>
            <div class="auth-field">
                <label class="auth-label" for="password">Adgangskode</label>
                <input id="password" name="password" class="auth-input" type="password" autocomplete="current-password" placeholder="••••••••" required />
            </div>
            <button type="submit" class="auth-submit">Log ind med e-mail</button>
        </form>
    }

    @if (LocalLoginEnabled)
    {
        <p class="auth-footer-link">Har du ikke en konto? <a href="@RegisterLink">Opret konto</a></p>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private bool LocalLoginEnabled => AuthOptions.Value.EnableEmailPasswordLogin;

    private bool GoogleEnabled => !string.IsNullOrEmpty(Configuration["OAuth:Google:ClientId"]);
    private bool MicrosoftEnabled => !string.IsNullOrEmpty(Configuration["OAuth:Microsoft:ClientId"]);
    private bool GitHubEnabled => !string.IsNullOrEmpty(Configuration["OAuth:GitHub:ClientId"]);
    private bool DiscordEnabled => !string.IsNullOrEmpty(Configuration["OAuth:Discord:ClientId"]);

    private bool AnyOAuthProvider => GoogleEnabled || MicrosoftEnabled || GitHubEnabled || DiscordEnabled;

    private string? ErrorMessage => Error switch
    {
        "invalid" => "Forkert e-mail eller adgangskode, eller ugyldig anmodning.",
        "disabled" => "Kontoen er deaktiveret.",
        "local_disabled" => "E-mail- og adgangskode-login er slået fra. Brug en af udbyderne ovenfor.",
        _ => null,
    };

    private string RegisterLink
    {
        get
        {
            var q = string.IsNullOrWhiteSpace(ReturnUrl) ? "" : $"?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
            return "/Account/Register" + q;
        }
    }

    private static string ChallengeUrl(string provider, string returnUrl, string? emailKind = null)
    {
        var q = $"provider={Uri.EscapeDataString(provider)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
        if (!string.IsNullOrEmpty(emailKind))
            q += $"&emailKind={Uri.EscapeDataString(emailKind)}";
        return $"/signin/challenge?{q}";
    }
}
