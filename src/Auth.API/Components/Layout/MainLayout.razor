@inherits LayoutComponentBase

<div class="merc-shell">
    <header class="merc-shell__header">
        <nav class="merc-shell__nav" aria-label="Hovednavigation">
            <a class="merc-shell__brand" href="/">
                <span class="merc-shell__mark" aria-hidden="true"></span>
                Mercantec Auth
            </a>
            <div class="merc-shell__links">
                <a href="/">Forside</a>
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <a href="/Admin/Users">Admin · brugere</a>
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="merc-shell__links merc-shell__links--end">
                <AuthorizeView>
                    <Authorized>
                        <a href="/signout">Log ud</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/Account/Login">Log ind</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </nav>
    </header>
    <main class="merc-shell__main">
        @Body
    </main>
    <footer class="merc-shell__footer">
        <div class="merc-shell__footer-inner">
            <p class="merc-shell__footer-line">OAuth2 · PKCE · JWT (RS256) · Mercantec Auth</p>
            <p class="merc-shell__footer-attrib" role="note">
                Undervisningsprojekt af <strong>MAGS</strong> — ikke Mercantecs officielle produktion.
                Kontakt: <a href="mailto:mags@mercantec.dk">mags@mercantec.dk</a>
            </p>
        </div>
    </footer>
</div>
