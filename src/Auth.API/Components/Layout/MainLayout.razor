@inherits LayoutComponentBase

<div class="merc-shell">
    <header class="merc-shell__header">
        <nav class="merc-shell__nav" aria-label="Hovednavigation">
            <a class="merc-shell__brand" href="/">
                <span class="merc-shell__mark" aria-hidden="true"></span>
                Mercantec Auth
            </a>
            <div class="merc-shell__links">
                <a href="/">Forside</a>
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <details class="merc-shell__menu">
                            <summary class="merc-shell__menu-summary">Admin</summary>
                            <div class="merc-shell__menu-panel" role="menu">
                                <a href="/Admin/Users" role="menuitem">Brugere</a>
                                <a href="/Admin/Clients" role="menuitem">Klienter</a>
                                <a href="/Admin/Usage" role="menuitem">Brug</a>
                                <a href="/Admin/Dokploy" role="menuitem" class="merc-shell__dokploy-link">
                                    <img class="merc-shell__dokploy-icon" src="/brand/dokploy-logo.svg" alt="" width="14" height="14" />
                                    Dokploy
                                </a>
                            </div>
                        </details>
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="merc-shell__links merc-shell__links--end">
                <AuthorizeView>
                    <Authorized>
                        <a class="merc-shell__dokploy-link" href="/dokploy">
                            <img class="merc-shell__dokploy-icon" src="/brand/dokploy-logo.svg" alt="" width="14" height="14" />
                            Dokploy
                        </a>
                        <a href="/Account/LinkedAccounts">Tilknyttede login</a>
                        <a href="/signout">Log ud</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/Account/Login">Log ind</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </nav>
    </header>
    <main class="merc-shell__main">
        @Body
    </main>
    <footer class="merc-shell__footer">
        <div class="merc-shell__footer-inner">
            <div class="merc-shell__footer-grid">
                <section class="merc-shell__footer-col" aria-label="Mercantec Auth og juridisk">
                    <p class="merc-shell__footer-kicker">Mercantec Auth</p>
                    <p class="merc-shell__footer-meta">OAuth2 · PKCE · JWT (RS256)</p>
                    <p class="merc-shell__footer-links-row">
                        <a href="/termsofservice">Vilkår</a>
                        <span class="merc-shell__footer-dot" aria-hidden="true">·</span>
                        <a href="/privacystatement">Privatliv</a>
                    </p>
                </section>
                <section class="merc-shell__footer-col" aria-label="Udvikling">
                    <p class="merc-shell__footer-kicker">Udvikling</p>
                    <p class="merc-shell__footer-text">
                        Udviklet af
                        <a href="https://mags.dk/" target="_blank" rel="noopener noreferrer">MAGS Solutions — mags.dk</a>
                        · platforme, webapps og drift (Mathias Gaardsdal&nbsp;Steenberg).
                    </p>
                </section>
                <section class="merc-shell__footer-col" aria-label="Undervisning og kontakt">
                    <p class="merc-shell__footer-kicker">Undervisning</p>
                    <p class="merc-shell__footer-text" role="note">
                        Undervisningsprojekt af <strong>MAGS</strong> — ikke Mercantecs officielle produktion.
                        Kontakt: <a href="mailto:mags@mercantec.dk">mags@mercantec.dk</a>
                    </p>
                </section>
            </div>
        </div>
    </footer>
</div>
