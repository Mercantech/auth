@page "/Account/Login"
@model LoginModel
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Log ind";
    ViewData["BrandSubtitle"] = "Sikker adgang til dine Mercantec-apps";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

<div class="auth-card">
    @await Html.PartialAsync("_LoginBrandHeader")

    <h2 class="auth-headline">Log ind</h2>
    <p class="auth-lead">@(Model.LocalLoginEnabled
        ? "Vælg en udbyder eller brug din Mercantec e-mail — ét sted for hele skolen."
        : Model.AnyOAuthProvider
            ? "Vælg en udbyder nedenfor."
            : Model.PasskeyEnabled
                ? "Log ind med passkey."
                : "Ingen login-metoder er tilgængelige for denne app.")</p>

    <input type="hidden" id="login-antiforgery" value="@tokens.RequestToken" />

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="auth-alert" role="alert">
            @Model.ErrorMessage
            @if (Model.Error == "email_unconfirmed")
            {
                <span> <a href="@Model.ConfirmEmailSentLink">Send bekræftelsesmail igen</a></span>
            }
        </div>
    }

    @if (!Model.AnyMethodEnabled)
    {
        <div class="auth-alert" role="alert">Ingen login-metode er aktiveret for denne app. Kontakt administratoren.</div>
    }

    @if (Model.PasskeyEnabled)
    {
        <div class="auth-actions">
            <button type="button" class="auth-action auth-action--passkey" id="passkey-login-btn">
                <span class="auth-action__icon" aria-hidden="true">
                    @await Html.PartialAsync("_SecurityIcon", "passkey")
                </span>
                <span class="auth-action__body">
                    <span class="auth-action__name">Log ind med passkey</span>
                    <span class="auth-action__hint">Face ID, Windows Hello eller sikkerhedsnøgle</span>
                </span>
                <svg class="auth-action__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
            </button>
        </div>
    }

    @if (Model.AnyOAuthProvider)
    {
        @await Html.PartialAsync("_OAuthProviderLinks", Model)
    }

    @if (Model.AnyOAuthProvider && Model.LocalLoginEnabled)
    {
        <div class="auth-divider"><span>eller</span></div>
    }

    @if (Model.LocalLoginEnabled)
    {
        <form method="post" action="/signin">
            <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <div class="auth-field">
                <label class="auth-label" for="email">E-mail</label>
                <input id="email" name="email" class="auth-input" type="email" autocomplete="username" placeholder="dig@eksempel.dk" required />
            </div>
            <div class="auth-field">
                <label class="auth-label" for="password">Adgangskode</label>
                <input id="password" name="password" class="auth-input" type="password" autocomplete="current-password" placeholder="••••••••" required />
            </div>
            <p class="auth-footer-link" style="margin-top:0;margin-bottom:1rem;text-align:right;">
                <a href="@Model.ForgotPasswordLink">Glemt adgangskode?</a>
            </p>
            <button type="submit" class="auth-submit">Log ind med e-mail</button>
        </form>
    }

    @if (Model.LocalLoginEnabled)
    {
        <p class="auth-footer-link">Har du ikke en konto? <a href="@Model.RegisterLink">Opret konto</a></p>
    }
</div>

@if (Model.PasskeyEnabled)
{
    <script src="@(Request.PathBase)/js/passkeys.js" asp-append-version="true"></script>
    <script>
        document.getElementById("passkey-login-btn")?.addEventListener("click", () => {
            const returnUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReturnUrl ?? "/"));
            const token = document.getElementById("login-antiforgery")?.value;
            if (!token) return;
            window.MercantecPasskeys.loginPasswordless(
                "@(Request.PathBase)/account/passkeys/login/options",
                "@(Request.PathBase)/account/passkeys/login/complete",
                token,
                returnUrl).catch(() => alert("Passkey-login fejlede. Har du registreret en passkey under Sikkerhed?"));
        });
    </script>
}
