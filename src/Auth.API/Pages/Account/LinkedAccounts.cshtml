@page "/Account/LinkedAccounts"
@model LinkedAccountsModel
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Tilknyttede login";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

<div class="auth-card linked-accounts account-hub-page">
    @await Html.PartialAsync("_AccountHubNav", "linked")

    <h1 class="auth-headline linked-accounts__title">Tilknyttede login</h1>
    <p class="auth-lead linked-accounts__intro">
        Én Mercantec-konto kan bruge flere udbydere — samme <strong>JWT <code class="linked-accounts__mono">sub</code></strong> til alle jeres apps.
        Hvis en ny udbyder matcher din e-mail, kan kontoerne også flettes automatisk ved login (se dokumentation).
    </p>

    @if (!string.IsNullOrEmpty(Model.BannerError))
    {
        <div class="auth-alert" role="alert">@Model.BannerError</div>
    }
    @if (Model.ShowUnlinkedOk)
    {
        <div class="linked-accounts-banner linked-accounts-banner--ok" role="status">Tilknytning fjernet.</div>
    }
    @if (Model.ShowPasswordSetOk)
    {
        <div class="linked-accounts-banner linked-accounts-banner--ok" role="status">Adgangskode er tilknyttet — du kan nu logge ind med e-mail og adgangskode (samme <code class="linked-accounts__mono">sub</code>).</div>
    }
    @if (Model.ShowDokployCreatedOk)
    {
        <div class="linked-accounts-banner linked-accounts-banner--ok" role="status">
            Dokploy-bruger er oprettet. Log ind på
            <a href="@Model.DokployUiUrl" target="_blank" rel="noopener">@Model.DokployUiUrl</a>
            med din e-mail og den Dokploy-adgangskode, du lige valgte.
        </div>
    }
    @if (Model.ShowDokployLinkedOk)
    {
        <div class="linked-accounts-banner linked-accounts-banner--ok" role="status">
            Din Auth-konto er nu linket til en eksisterende Dokploy-bruger.
            <a href="@Model.DokployUiUrl" target="_blank" rel="noopener">Åbn deploy</a>
        </div>
    }
    @if (Model.ShowDokployAlreadyOk)
    {
        <div class="linked-accounts-banner linked-accounts-banner--ok" role="status">
            Du har allerede en Dokploy-bruger.
            <a href="@Model.DokployUiUrl" target="_blank" rel="noopener">Åbn deploy</a>
        </div>
    }

    @if (Model.CanSetPassword)
    {
        <section class="linked-section linked-section--bordered" aria-labelledby="password-heading">
            <h2 id="password-heading" class="linked-section__heading">E-mail og adgangskode</h2>
            <p class="linked-section__lede">
                Tilføj adgangskode til din eksisterende Mercantec-konto. Brug den <strong>samme e-mail</strong> som ved Google, Microsoft eller andre tilknyttede login — så forbliver JWT <code class="linked-accounts__mono">sub</code> uændret.
            </p>
            <form class="linked-password-form" method="post" action="@(Request.PathBase)/account/password/set">
                <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrlParam" />
                <label class="auth-label" for="password-email">E-mail</label>
                <input id="password-email" name="email" class="auth-input" type="email" autocomplete="username" required
                       value="@Model.SuggestedPasswordEmail" placeholder="dig@eksempel.dk" />
                <label class="auth-label" for="password-new">Adgangskode (min. 8 tegn)</label>
                <input id="password-new" name="password" class="auth-input" type="password" autocomplete="new-password" required minlength="8" maxlength="100" />
                <label class="auth-label" for="password-confirm">Gentag adgangskode</label>
                <input id="password-confirm" name="passwordConfirm" class="auth-input" type="password" autocomplete="new-password" required minlength="8" maxlength="100" />
                <button type="submit" class="auth-btn auth-btn--primary linked-password-form__submit">Gem adgangskode</button>
            </form>
        </section>
    }

    @if (Model.DokploySectionVisible)
    {
        <section class="linked-section linked-section--bordered" aria-labelledby="dokploy-heading">
            <h2 id="dokploy-heading" class="linked-section__heading">Dokploy (deploy)</h2>
            <p class="linked-section__lede">
                Dokploy har ikke selv-registrering. Her opretter Auth en Dokploy-bruger med e-mail + adgangskode
                (samme e-mail som din Auth-konto). Login til deploy sker stadig på Dokploy — ikke via Auth SSO.
            </p>
            @if (Model.DokployIsProvisioned)
            {
                <p class="linked-section__muted">
                    Status: <strong>aktiv</strong>
                </p>
                <p>
                    <a class="auth-btn auth-btn--primary" href="@Model.DokployUiUrl" target="_blank" rel="noopener">Åbn deploy</a>
                </p>
            }
            else if (string.IsNullOrWhiteSpace(Model.UserEmail) && string.IsNullOrWhiteSpace(Model.SuggestedPasswordEmail))
            {
                <p class="linked-section__muted">Du mangler en e-mail på din Auth-konto, før Dokploy-brugeren kan oprettes.</p>
            }
            else
            {
                <form class="linked-password-form" method="post" action="@(Request.PathBase)/account/dokploy/provision">
                    <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrlParam" />
                    <label class="auth-label" for="dokploy-password">Dokploy-adgangskode (min. 8 tegn)</label>
                    <input id="dokploy-password" name="password" class="auth-input" type="password" autocomplete="new-password" required minlength="8" maxlength="100" />
                    <label class="auth-label" for="dokploy-password-confirm">Gentag Dokploy-adgangskode</label>
                    <input id="dokploy-password-confirm" name="passwordConfirm" class="auth-input" type="password" autocomplete="new-password" required minlength="8" maxlength="100" />
                    <button type="submit" class="auth-btn auth-btn--primary linked-password-form__submit">Opret Dokploy-bruger</button>
                </form>
                @if (!string.IsNullOrWhiteSpace(Model.DokployLastError))
                {
                    <p class="linked-section__muted" style="margin-top:0.75rem">Sidste forsøg: @Model.DokployLastError</p>
                }
            }
        </section>
    }

    <section class="linked-section" aria-labelledby="link-more-heading">
        <h2 id="link-more-heading" class="linked-section__heading">Tilknyt mere</h2>
        <p class="linked-section__lede">
            Vælg en udbyder nedenfor. Du sendes til udbyderens login og derefter tilbage til denne side. Du skal allerede være logget ind her som Mercantec-bruger.
        </p>
        @if (Model.OfferedLinkProviders.Count == 0)
        {
            <p class="linked-section__muted">Ingen OAuth-udbydere konfigureret på serveren.</p>
        }
        else
        {
            <div class="auth-providers linked-accounts__provider-grid">
                @foreach (var p in Model.OfferedLinkProviders)
                {
                    @await Html.PartialAsync("_LinkProviderTile", p)
                }
            </div>
        }
    </section>

    <section class="linked-section linked-section--bordered" aria-labelledby="connections-heading">
        <h2 id="connections-heading" class="linked-section__heading">Aktive tilknytninger</h2>

        @if (Model.ExternalLogins.Count == 0)
        {
            <p class="linked-empty">Du har ikke tilknyttet ekstra udbydere endnu. Brug felterne ovenfor.</p>
        }
        else
        {
            <ul class="linked-connections" role="list">
                @foreach (var row in Model.ExternalLogins)
                {
                    <li class="linked-conn-row @LinkedAccountsModel.ConnectedRowModifierClass(row.Provider)">
                        <span class="linked-conn-row__badge" aria-hidden="true">
                            @await Html.PartialAsync("_ProviderOAuthIcon", row.Provider)
                        </span>
                        <div class="linked-conn-row__body">
                            <span class="linked-conn-row__name">@row.ProviderLabel</span>
                            <span class="linked-conn-row__meta">
                                @(string.IsNullOrEmpty(row.ProviderEmail) ? "Skjult eller ingen e-mail fra udbyder" : row.ProviderEmail)
                                <span aria-hidden="true"> · </span>
                                Tilføjet @LinkedAccountsModel.FormatLinkedLocal(row.LinkedAtUtc)
                            </span>
                        </div>
                        <div class="linked-conn-row__action">
                            @if (Model.ExternalLogins.Count > 1 || Model.HasPasswordLogin)
                            {
                                <form method="post" action="@(Request.PathBase)/account/link/remove">
                                    <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                                    <input type="hidden" name="id" value="@row.Id" />
                                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrlParam" />
                                    <button type="submit" class="linked-conn-row__unlink">Fjern</button>
                                </form>
                            }
                            else
                            {
                                <span class="linked-conn-row__muted">Sidste login — tilknyt en anden før fjern.</span>
                            }
                        </div>
                    </li>
                }
            </ul>
        }

        @if (Model.HasPasswordLogin)
        {
            <p class="linked-section__footnote">Du har også <strong>e-mail og adgangskode</strong> som login.</p>
        }
    </section>
</div>
