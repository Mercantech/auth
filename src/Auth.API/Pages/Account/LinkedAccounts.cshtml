@page "/Account/LinkedAccounts"
@model LinkedAccountsModel
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Tilknyttede login";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

<div class="auth-card linked-accounts">
    <h1 class="auth-headline linked-accounts__title">Tilknyttede login</h1>
    <p class="auth-lead linked-accounts__intro">
        Én Mercantec-konto kan bruge flere udbydere — samme <strong>JWT <code class="linked-accounts__mono">sub</code></strong> til alle jeres apps.
        Hvis en ny udbyder matcher din e-mail, kan kontoerne også flettes automatisk ved login (se dokumentation).
    </p>
    <p class="linked-accounts__breadcrumb">
        <a class="linked-accounts__back" href="/">← Til forsiden</a>
    </p>

    @if (!string.IsNullOrEmpty(Model.BannerError))
    {
        <div class="auth-alert" role="alert">@Model.BannerError</div>
    }
    @if (Model.ShowUnlinkedOk)
    {
        <div class="linked-accounts-banner linked-accounts-banner--ok" role="status">Tilknytning fjernet.</div>
    }

    <section class="linked-section" aria-labelledby="link-more-heading">
        <h2 id="link-more-heading" class="linked-section__heading">Tilknyt mere</h2>
        <p class="linked-section__lede">
            Vælg en udbyder nedenfor. Du sendes til udbyderens login og derefter tilbage til denne side. Du skal allerede være logget ind her som Mercantec-bruger.
        </p>
        @if (Model.OfferedLinkProviders.Count == 0)
        {
            <p class="linked-section__muted">Ingen OAuth-udbydere konfigureret på serveren.</p>
        }
        else
        {
            <div class="auth-providers linked-accounts__provider-grid">
                @foreach (var p in Model.OfferedLinkProviders)
                {
                    @await Html.PartialAsync("_LinkProviderTile", p)
                }
            </div>
        }
    </section>

    <section class="linked-section linked-section--bordered" aria-labelledby="connections-heading">
        <h2 id="connections-heading" class="linked-section__heading">Aktive tilknytninger</h2>

        @if (Model.ExternalLogins.Count == 0)
        {
            <p class="linked-empty">Du har ikke tilknyttet ekstra udbydere endnu. Brug felterne ovenfor.</p>
        }
        else
        {
            <ul class="linked-connections" role="list">
                @foreach (var row in Model.ExternalLogins)
                {
                    <li class="linked-conn-row @LinkedAccountsModel.ConnectedRowModifierClass(row.Provider)">
                        <span class="linked-conn-row__badge" aria-hidden="true">
                            @await Html.PartialAsync("_ProviderOAuthIcon", row.Provider)
                        </span>
                        <div class="linked-conn-row__body">
                            <span class="linked-conn-row__name">@row.ProviderLabel</span>
                            <span class="linked-conn-row__meta">
                                @(string.IsNullOrEmpty(row.ProviderEmail) ? "Skjult eller ingen e-mail fra udbyder" : row.ProviderEmail)
                                <span aria-hidden="true"> · </span>
                                Tilføjet @LinkedAccountsModel.FormatLinkedLocal(row.LinkedAtUtc)
                            </span>
                        </div>
                        <div class="linked-conn-row__action">
                            @if (Model.ExternalLogins.Count > 1 || Model.HasPasswordLogin)
                            {
                                <form method="post" action="@(Request.PathBase)/account/link/remove">
                                    <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                                    <input type="hidden" name="id" value="@row.Id" />
                                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrlParam" />
                                    <button type="submit" class="linked-conn-row__unlink">Fjern</button>
                                </form>
                            }
                            else
                            {
                                <span class="linked-conn-row__muted">Sidste login — tilknyt en anden før fjern.</span>
                            }
                        </div>
                    </li>
                }
            </ul>
        }

        @if (Model.HasPasswordLogin)
        {
            <p class="linked-section__footnote">Du har også <strong>e-mail og adgangskode</strong> som login.</p>
        }
    </section>
</div>
