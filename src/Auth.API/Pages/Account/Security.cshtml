@page "/Account/Security"
@model Auth.API.Pages.Account.SecurityModel
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Sikkerhed";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
    var pathBase = Request.PathBase.Value ?? "";
}

<div class="auth-card security-page account-hub-page">
    @await Html.PartialAsync("_AccountHubNav", "security")

    <header class="security-hero">
        <div class="security-hero__mark" aria-hidden="true">
            @await Html.PartialAsync("_SecurityIcon", "shield")
        </div>
        <div class="security-hero__text">
            <h1 class="security-hero__title">Sikkerhed</h1>
            <p class="security-hero__lede">
                Beskyt din Mercantec-konto med authenticator-app og passkeys. Bruges som ekstra trin ved login.
            </p>
        </div>
    </header>

    @if (!string.IsNullOrEmpty(Model.BannerMessage))
    {
        <div class="security-alert security-alert--ok" role="status">
            <span class="security-alert__icon">@await Html.PartialAsync("_SecurityIcon", "check")</span>
            <span>@Model.BannerMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.BannerError))
    {
        <div class="auth-alert" role="alert">@Model.BannerError</div>
    }

    <article class="security-panel security-panel--totp" aria-labelledby="totp-heading">
        <div class="security-panel__head">
            <div class="security-panel__icon security-panel__icon--totp" aria-hidden="true">
                @await Html.PartialAsync("_SecurityIcon", "totp")
            </div>
            <div class="security-panel__titles">
                <h2 id="totp-heading" class="security-panel__title">Authenticator-app</h2>
                <p class="security-panel__subtitle">TOTP · Google Authenticator, Microsoft Authenticator m.fl.</p>
            </div>
            @if (Model.TotpEnabled)
            {
                <span class="security-badge security-badge--on">
                    @await Html.PartialAsync("_SecurityIcon", "check")
                    Aktiv
                </span>
            }
            else
            {
                <span class="security-badge security-badge--setup">Opsætning</span>
            }
        </div>

        <div class="security-panel__body">
            @if (Model.TotpEnabled)
            {
                <p class="security-panel__text">
                    Ved næste login skal du indtaste en 6-cifret kode fra din app.
                </p>
                <form class="security-form" method="post" action="@(pathBase)/account/mfa/totp/disable">
                    <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                    <label class="auth-label" for="disable-code">Bekræft med kode for at slå fra</label>
                    <input id="disable-code" name="code" class="auth-input security-input--code" inputmode="numeric" autocomplete="one-time-code" placeholder="000000" maxlength="8" required />
                    <button type="submit" class="auth-btn auth-btn--danger auth-btn--block security-btn--danger">
                        @await Html.PartialAsync("_SecurityIcon", "trash")
                        Deaktivér authenticator
                    </button>
                </form>

                @if (Model.HasPasskeys)
                {
                    <section class="security-totp-passkey-fallback" aria-labelledby="totp-passkey-fallback-heading">
                        <div class="auth-divider security-divider" role="separator"><span>eller</span></div>
                        <h3 id="totp-passkey-fallback-heading" class="security-totp-passkey-fallback__title">
                            @await Html.PartialAsync("_SecurityIcon", "passkey")
                            Nulstil med passkey
                        </h3>
                        <p class="security-panel__text security-totp-passkey-fallback__text">
                            Virker authenticator-appen ikke? Bekræft med en af dine registrerede passkeys (@Model.Passkeys.Count @(Model.Passkeys.Count == 1 ? "enhed" : "enheder")) i stedet for TOTP-kode.
                        </p>
                        <button type="button" class="auth-btn auth-btn--passkey auth-btn--block" id="disable-totp-passkey-btn">
                            @await Html.PartialAsync("_SecurityIcon", "passkey")
                            Deaktivér authenticator med passkey
                        </button>
                    </section>
                }
                else
                {
                    <p class="security-panel__text security-panel__text--muted">
                        Tip: Registrér en passkey nedenfor — så kan du nulstille authenticator uden TOTP-kode, hvis appen fejler.
                    </p>
                }
            }
            else
            {
                <ol class="security-steps">
                    <li class="security-steps__item security-steps__item--current">
                        <span class="security-steps__num">1</span>
                        <span>Scan QR-koden</span>
                    </li>
                    <li class="security-steps__item">
                        <span class="security-steps__num">2</span>
                        <span>Bekræft med 6 cifre</span>
                    </li>
                </ol>

                @if (!string.IsNullOrEmpty(Model.SetupUri))
                {
                    <div class="security-qr-panel">
                        @if (!string.IsNullOrEmpty(Model.SetupQrDataUrl))
                        {
                            <img src="@Model.SetupQrDataUrl" width="200" height="200" alt="QR-kode til authenticator-app" class="security-qr-panel__img" />
                        }
                    </div>

                    <div class="security-secret">
                        <span class="security-secret__label">Manuel nøgle</span>
                        <div class="security-secret__row">
                            <code class="security-secret__code" id="totp-secret">@Model.SetupSecret</code>
                            <button type="button" class="security-secret__copy" id="copy-totp-secret" title="Kopiér nøgle">
                                @await Html.PartialAsync("_SecurityIcon", "copy")
                                <span class="security-secret__copy-text">Kopiér</span>
                            </button>
                        </div>
                    </div>
                }

                <form class="security-form" method="post" action="@(pathBase)/account/mfa/totp/confirm">
                    <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                    <label class="auth-label" for="confirm-code">6-cifret kode fra appen</label>
                    <input id="confirm-code" name="code" class="auth-input security-input--code" inputmode="numeric" autocomplete="one-time-code" placeholder="000000" maxlength="8" required />
                    <button type="submit" class="auth-btn auth-btn--primary auth-btn--block">
                        @await Html.PartialAsync("_SecurityIcon", "check")
                        Aktivér authenticator
                    </button>
                </form>
                <form method="post" action="@(pathBase)/account/mfa/totp/setup" class="security-form security-form--inline">
                    <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                    <button type="submit" class="auth-btn auth-btn--ghost auth-btn--block">
                        @await Html.PartialAsync("_SecurityIcon", "refresh")
                        Generér ny QR-kode
                    </button>
                </form>
            }
        </div>
    </article>

    <article class="security-panel security-panel--passkey" aria-labelledby="passkey-heading">
        <div class="security-panel__head">
            <div class="security-panel__icon security-panel__icon--passkey" aria-hidden="true">
                @await Html.PartialAsync("_SecurityIcon", "passkey")
            </div>
            <div class="security-panel__titles">
                <h2 id="passkey-heading" class="security-panel__title">Passkeys</h2>
                <p class="security-panel__subtitle">WebAuthn · Face ID, Windows Hello, YubiKey</p>
            </div>
            @if (Model.Passkeys.Count > 0)
            {
                <span class="security-badge security-badge--count">@Model.Passkeys.Count @(Model.Passkeys.Count == 1 ? "enhed" : "enheder")</span>
            }
        </div>

        <div class="security-panel__body">
            <p class="security-panel__text">
                Log ind uden adgangskode, eller brug passkey som anden faktor efter OAuth/adgangskode.
            </p>

            @if (Model.Passkeys.Count == 0)
            {
                <p class="security-empty">
                    @await Html.PartialAsync("_SecurityIcon", "lock")
                    Ingen passkeys endnu — tilføj en nedenfor.
                </p>
            }
            else
            {
                <ul class="security-passkey-list" role="list">
                    @foreach (var p in Model.Passkeys)
                    {
                        <li class="security-passkey-item">
                            <div class="security-passkey-item__icon" aria-hidden="true">
                                @await Html.PartialAsync("_SecurityIcon", "passkey")
                            </div>
                            <div class="security-passkey-item__body">
                                <span class="security-passkey-item__name">@p.FriendlyName</span>
                                <span class="security-passkey-item__meta">
                                    Oprettet @p.CreatedAtUtc.ToString("d. MMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("da-DK"))
                                    @if (p.LastUsedAtUtc is not null)
                                    {
                                        <span> · Sidst brugt @p.LastUsedAtUtc.Value.ToString("d. MMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("da-DK"))</span>
                                    }
                                </span>
                            </div>
                            <form method="post" action="@(pathBase)/account/passkeys/@p.Id/delete" class="security-passkey-item__form">
                                <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
                                <button type="submit" class="security-passkey-item__remove" title="Fjern @p.FriendlyName">
                                    @await Html.PartialAsync("_SecurityIcon", "trash")
                                    <span>Fjern</span>
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            }

            <div class="security-add-passkey">
                <h3 class="security-add-passkey__title">Tilføj ny passkey</h3>
                <label class="auth-label" for="passkey-name">Navn på enhed</label>
                <input id="passkey-name" class="auth-input" value="Min passkey" maxlength="80" autocomplete="off" />
                <button type="button" class="auth-btn auth-btn--passkey auth-btn--block" id="add-passkey-btn">
                    @await Html.PartialAsync("_SecurityIcon", "plus")
                    Registrér passkey
                </button>
            </div>
        </div>
    </article>
</div>

<script src="@(pathBase)/js/passkeys.js"></script>
<script>
    document.getElementById("add-passkey-btn")?.addEventListener("click", () => {
        const name = document.getElementById("passkey-name")?.value?.trim() || "Passkey";
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        window.MercantecPasskeys.register(
            "@(pathBase)/account/passkeys/register/options",
            "@(pathBase)/account/passkeys/register/complete",
            token,
            name).then(() => location.reload()).catch(() => alert("Passkey-registrering fejlede."));
    });

    document.getElementById("disable-totp-passkey-btn")?.addEventListener("click", () => {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        window.MercantecPasskeys.assertForMfa(
            "@(pathBase)/account/mfa/totp/disable/passkey/options",
            "@(pathBase)/account/mfa/totp/disable/passkey/complete",
            token,
            "@(pathBase)/Account/Security?totp_disabled=1")
            .catch(() => alert("Passkey-bekræftelse fejlede — authenticator er ikke slået fra."));
    });

    document.getElementById("copy-totp-secret")?.addEventListener("click", async () => {
        const el = document.getElementById("totp-secret");
        const btn = document.getElementById("copy-totp-secret");
        if (!el?.textContent || !btn) return;
        try {
            await navigator.clipboard.writeText(el.textContent.trim());
            const label = btn.querySelector(".security-secret__copy-text");
            if (label) {
                const prev = label.textContent;
                label.textContent = "Kopieret!";
                setTimeout(() => { label.textContent = prev; }, 2000);
            }
        } catch {
            alert("Kunne ikke kopiere — markér nøglen manuelt.");
        }
    });
</script>
