@page "/Account/ForgotPassword"
@model ForgotPasswordModel
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Glemt adgangskode";
    ViewData["BrandSubtitle"] = "Nulstil din adgangskode";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

<div class="auth-card">
    @await Html.PartialAsync("_LoginBrandHeader")

    <h2 class="auth-headline">Glemt adgangskode?</h2>
    <p class="auth-lead">Indtast din e-mail — vi sender et link til at vælge en ny adgangskode.</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="auth-alert" role="alert">@Model.ErrorMessage</div>
    }

    @if (Model.LocalLoginEnabled)
    {
        <form method="post" action="/account/password/forgot">
            <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <div class="auth-field">
                <label class="auth-label" for="email">E-mail</label>
                <input id="email" name="email" class="auth-input" type="email" autocomplete="username" placeholder="dig@eksempel.dk" required />
            </div>
            <button type="submit" class="auth-submit">Send nulstillingslink</button>
        </form>
    }

    <p class="auth-footer-link">Tilbage til <a href="@Model.LoginLink">log ind</a></p>
</div>
