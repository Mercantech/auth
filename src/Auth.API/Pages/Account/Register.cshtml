@page "/Account/Register"
@model RegisterModel
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Opret konto";
    ViewData["BrandSubtitle"] = "Opret din konto";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

<div class="auth-card">
    @await Html.PartialAsync("_LoginBrandHeader")

    <h2 class="auth-headline">Kom i gang</h2>
    <p class="auth-lead">@(Model.LocalLoginEnabled
        ? "Ny konto oprettes her. Har du allerede logget ind med Google, Microsoft m.fl., kan du bruge samme e-mail — så tilknyttes adgangskode til din eksisterende bruger (samme sub). Eller tilføj adgangskode under Tilknyttede login efter OAuth-login."
        : "Selvoprettelse med e-mail og adgangskode er slået fra. Brug Google, Microsoft eller en anden udbyder fra loginsiden.")</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="auth-alert" role="alert">@Model.ErrorMessage</div>
    }

    @if (Model.LocalLoginEnabled)
    {
        <form method="post" action="/signup">
            <input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <div class="auth-field">
                <label class="auth-label" for="displayName">Vist navn</label>
                <input id="displayName" name="displayName" class="auth-input" maxlength="120" placeholder="Fx Dit navn" required />
            </div>
            <div class="auth-field">
                <label class="auth-label" for="email">E-mail</label>
                <input id="email" name="email" class="auth-input" type="email" autocomplete="username" placeholder="dig@eksempel.dk" required />
            </div>
            <div class="auth-field">
                <label class="auth-label" for="password">Adgangskode</label>
                <input id="password" name="password" class="auth-input" type="password" autocomplete="new-password" minlength="8" maxlength="100" placeholder="Mindst 8 tegn" required />
            </div>
            <button type="submit" class="auth-submit">Opret konto</button>
        </form>
    }

    <p class="auth-footer-link">Har du allerede en konto? <a href="@Model.LoginLink">Log ind</a></p>
</div>
